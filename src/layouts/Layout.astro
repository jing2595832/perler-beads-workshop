---
export interface Props {
  title: string;
  description?: string;
  lang?: 'zh' | 'en' | 'ja';
}

const { 
  title, 
  description = '拼豆豆工坊 - 创意像素艺术设计与分享平台',
  lang = 'zh'
} = Astro.props;

const langMap = {
  zh: 'zh-CN',
  en: 'en-US',
  ja: 'ja-JP'
};

const currentLang = langMap[lang];

const seoData = {
  zh: {
    title: `${title} | 拼豆豆工坊`,
    description: description,
    keywords: '拼豆豆,像素艺术,拼豆图纸,拼豆设计,手工DIY'
  },
  en: {
    title: `${title} | Perler Beads Workshop`,
    description: 'Perler Beads Workshop - Creative Pixel Art Design & Sharing Platform',
    keywords: 'perler beads,pixel art,bead patterns,DIY crafts,fuse beads'
  },
  ja: {
    title: `${title} | アイロンビーズ工房`,
    description: 'アイロンビーズ工房 - クリエイティブなドット絵デザイン＆シェアリングプラットフォーム',
    keywords: 'アイロンビーズ,ドット絵,ビーズ図案,ハンドメイド,クラフト'
  }
};

const seo = seoData[lang];
---

<!DOCTYPE html>
<html lang={currentLang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={seo.description} />
  <meta name="keywords" content={seo.keywords} />
  <meta name="author" content="拼豆豆工坊" />
  
  <!-- Open Graph -->
  <meta property="og:title" content={seo.title} />
  <meta property="og:description" content={seo.description} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="拼豆豆工坊" />
  
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={seo.title} />
  <meta name="twitter:description" content={seo.description} />
  
  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  
  <!-- Google Fonts - Press Start 2P -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Noto+Sans+SC:wght@400;500;700&family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet" />
  
  <title>{seo.title}</title>
  
  <style is:global>
    :root {
      --color-primary: #FF6B6B;
      --color-secondary: #4ECDC4;
      --color-accent: #FFE66D;
      --color-background: #F7F7F7;
      --color-text: #2C3E50;
      --color-border: #2C3E50;
      --color-white: #FFFFFF;
      --color-shadow: rgba(44, 62, 80, 0.2);
      
      --font-pixel: 'Press Start 2P', cursive;
      --font-body-zh: 'Noto Sans SC', sans-serif;
      --font-body-ja: 'Noto Sans JP', sans-serif;
      --font-body-en: system-ui, -apple-system, sans-serif;
      
      --spacing-xs: 0.25rem;
      --spacing-sm: 0.5rem;
      --spacing-md: 1rem;
      --spacing-lg: 1.5rem;
      --spacing-xl: 2rem;
      --spacing-2xl: 3rem;
      
      --border-width: 3px;
      --border-radius: 0;
      --shadow-offset: 4px;
    }
    
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    html {
      scroll-behavior: smooth;
    }
    
    body {
      font-family: var(--font-body-zh);
      background-color: var(--color-background);
      color: var(--color-text);
      line-height: 1.6;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }
    
    body[data-lang="en"] {
      font-family: var(--font-body-en);
    }
    
    body[data-lang="ja"] {
      font-family: var(--font-body-ja);
    }
    
    h1, h2, h3, h4, h5, h6 {
      font-family: var(--font-pixel);
      line-height: 1.4;
      margin-bottom: var(--spacing-md);
    }
    
    h1 {
      font-size: clamp(1.5rem, 4vw, 2.5rem);
    }
    
    h2 {
      font-size: clamp(1.25rem, 3vw, 2rem);
    }
    
    h3 {
      font-size: clamp(1rem, 2vw, 1.5rem);
    }
    
    p {
      margin-bottom: var(--spacing-md);
    }
    
    a {
      color: var(--color-primary);
      text-decoration: none;
      transition: all 0.2s ease;
    }
    
    a:hover {
      color: var(--color-secondary);
    }
    
    img {
      max-width: 100%;
      height: auto;
      display: block;
    }
    
    button {
      font-family: inherit;
      cursor: pointer;
      border: none;
      background: none;
    }
    
    /* Pixel Button Style */
    .pixel-btn {
      display: inline-block;
      padding: var(--spacing-sm) var(--spacing-md);
      background-color: var(--color-primary);
      color: var(--color-white);
      font-family: var(--font-pixel);
      font-size: 0.75rem;
      border: var(--border-width) solid var(--color-border);
      box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--color-border);
      transition: all 0.1s ease;
      text-transform: uppercase;
    }
    
    .pixel-btn:hover {
      transform: translate(2px, 2px);
      box-shadow: calc(var(--shadow-offset) - 2px) calc(var(--shadow-offset) - 2px) 0 var(--color-border);
    }
    
    .pixel-btn:active {
      transform: translate(var(--shadow-offset), var(--shadow-offset));
      box-shadow: 0 0 0 var(--color-border);
    }
    
    .pixel-btn.secondary {
      background-color: var(--color-secondary);
    }
    
    .pixel-btn.accent {
      background-color: var(--color-accent);
      color: var(--color-text);
    }
    
    /* Pixel Card Style */
    .pixel-card {
      background-color: var(--color-white);
      border: var(--border-width) solid var(--color-border);
      box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--color-shadow);
      padding: var(--spacing-lg);
    }
    
    /* Pixel Border */
    .pixel-border {
      border: var(--border-width) solid var(--color-border);
    }
    
    /* Container */
    .container {
      width: 100%;
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 var(--spacing-md);
    }
    
    /* Main Content */
    main {
      flex: 1;
      padding: var(--spacing-xl) 0;
    }
    
    /* Screen Reader Only */
    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
  </style>
</head>
<body data-lang={lang}>
  <slot />
  
  <script>
    // Language persistence
    const savedLang = localStorage.getItem('preferred-language');
    if (savedLang) {
      const body = document.body;
      body.setAttribute('data-lang', savedLang);
    }
  </script>
</body>
</html>

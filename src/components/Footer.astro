---
export interface Props {
  currentLang?: 'zh' | 'en' | 'ja';
}

const { currentLang = 'zh' } = Astro.props;

const footerData = {
  zh: {
    copyright: '© 2024 拼豆豆工坊',
    original: '原创内容 · 手工制作 · 像素艺术',
    links: {
      about: '关于我们',
      contact: '联系我们',
      privacy: '隐私政策',
      terms: '使用条款'
    },
    social: {
      title: '关注我们'
    }
  },
  en: {
    copyright: '© 2024 Perler Beads Workshop',
    original: 'Original Content · Handmade · Pixel Art',
    links: {
      about: 'About Us',
      contact: 'Contact',
      privacy: 'Privacy Policy',
      terms: 'Terms of Use'
    },
    social: {
      title: 'Follow Us'
    }
  },
  ja: {
    copyright: '© 2024 アイロンビーズ工房',
    original: 'オリジナルコンテンツ · ハンドメイド · ドット絵',
    links: {
      about: '私たちについて',
      contact: 'お問い合わせ',
      privacy: 'プライバシーポリシー',
      terms: '利用規約'
    },
    social: {
      title: 'フォローする'
    }
  }
};

const content = footerData[currentLang];

const footerLinks = [
  { label: content.links.about, href: '/about' },
  { label: content.links.contact, href: '/contact' },
  { label: content.links.privacy, href: '/privacy' },
  { label: content.links.terms, href: '/terms' }
];

const socialLinks = [
  { 
    name: 'Twitter', 
    href: 'https://twitter.com',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`
  },
  { 
    name: 'Instagram', 
    href: 'https://instagram.com',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>`
  },
  { 
    name: 'YouTube', 
    href: 'https://youtube.com',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>`
  }
];
---

<footer class="footer">
  <div class="container">
    <!-- Pixel Art Decoration -->
    <div class="pixel-decoration">
      <div class="pixel-row">
        <span class="pixel" style="--color: #FF6B6B;"></span>
        <span class="pixel" style="--color: #4ECDC4;"></span>
        <span class="pixel" style="--color: #FFE66D;"></span>
        <span class="pixel" style="--color: #FF6B6B;"></span>
        <span class="pixel" style="--color: #4ECDC4;"></span>
        <span class="pixel" style="--color: #FFE66D;"></span>
        <span class="pixel" style="--color: #FF6B6B;"></span>
        <span class="pixel" style="--color: #4ECDC4;"></span>
        <span class="pixel" style="--color: #FFE66D;"></span>
        <span class="pixel" style="--color: #FF6B6B;"></span>
        <span class="pixel" style="--color: #4ECDC4;"></span>
        <span class="pixel" style="--color: #FFE66D;"></span>
      </div>
    </div>
    
    <div class="footer-content">
      <!-- Brand Section -->
      <div class="footer-brand">
        <div class="footer-logo">
          <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="4" y="4" width="6" height="6" fill="#FF6B6B"/>
            <rect x="12" y="4" width="6" height="6" fill="#4ECDC4"/>
            <rect x="20" y="4" width="6" height="6" fill="#FFE66D"/>
            <rect x="4" y="12" width="6" height="6" fill="#4ECDC4"/>
            <rect x="12" y="12" width="6" height="6" fill="#FF6B6B"/>
            <rect x="20" y="12" width="6" height="6" fill="#4ECDC4"/>
            <rect x="4" y="20" width="6" height="6" fill="#FFE66D"/>
            <rect x="12" y="20" width="6" height="6" fill="#4ECDC4"/>
            <rect x="20" y="20" width="6" height="6" fill="#FF6B6B"/>
          </svg>
        </div>
        <p class="copyright">{content.copyright}</p>
        <p class="original">{content.original}</p>
      </div>
      
      <!-- Links Section -->
      <nav class="footer-links" aria-label="Footer navigation">
        <ul class="links-list">
          {footerLinks.map((link) => (
            <li class="link-item">
              <a href={link.href} class="footer-link">{link.label}</a>
            </li>
          ))}
        </ul>
      </nav>
      
      <!-- Social Section -->
      <div class="footer-social">
        <h3 class="social-title">{content.social.title}</h3>
        <div class="social-icons">
          {socialLinks.map((social) => (
            <a 
              href={social.href} 
              class="social-link" 
              target="_blank" 
              rel="noopener noreferrer"
              aria-label={social.name}
            >
              <span class="social-icon" set:html={social.icon} />
            </a>
          ))}
        </div>
      </div>
    </div>
    
    <!-- Bottom Bar -->
    <div class="footer-bottom">
      <p class="made-with">
        Made with 
        <span class="heart">❤️</span> 
        & 
        <span class="beads">🎨</span>
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-white);
    border-top: var(--border-width) solid var(--color-border);
    margin-top: auto;
  }
  
  /* Pixel Decoration */
  .pixel-decoration {
    padding: var(--spacing-lg) 0;
    display: flex;
    justify-content: center;
    border-bottom: 2px dashed var(--color-border);
  }
  
  .pixel-row {
    display: flex;
    gap: 4px;
  }
  
  .pixel {
    width: 16px;
    height: 16px;
    background-color: var(--color);
    border: 2px solid var(--color-border);
    animation: pixelPulse 2s ease-in-out infinite;
  }
  
  .pixel:nth-child(1) { animation-delay: 0s; }
  .pixel:nth-child(2) { animation-delay: 0.1s; }
  .pixel:nth-child(3) { animation-delay: 0.2s; }
  .pixel:nth-child(4) { animation-delay: 0.3s; }
  .pixel:nth-child(5) { animation-delay: 0.4s; }
  .pixel:nth-child(6) { animation-delay: 0.5s; }
  .pixel:nth-child(7) { animation-delay: 0.6s; }
  .pixel:nth-child(8) { animation-delay: 0.7s; }
  .pixel:nth-child(9) { animation-delay: 0.8s; }
  .pixel:nth-child(10) { animation-delay: 0.9s; }
  .pixel:nth-child(11) { animation-delay: 1s; }
  .pixel:nth-child(12) { animation-delay: 1.1s; }
  
  @keyframes pixelPulse {
    0%, 100% {
      transform: scale(1);
      opacity: 1;
    }
    50% {
      transform: scale(0.85);
      opacity: 0.7;
    }
  }
  
  /* Footer Content */
  .footer-content {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-xl);
    padding: var(--spacing-xl) 0;
  }
  
  @media (min-width: 768px) {
    .footer-content {
      grid-template-columns: 1.5fr 1fr 1fr;
      align-items: start;
    }
  }
  
  /* Brand Section */
  .footer-brand {
    text-align: center;
  }
  
  @media (min-width: 768px) {
    .footer-brand {
      text-align: left;
    }
  }
  
  .footer-logo {
    width: 48px;
    height: 48px;
    margin: 0 auto var(--spacing-md);
    border: 3px solid var(--color-border);
    background-color: var(--color-white);
  }
  
  @media (min-width: 768px) {
    .footer-logo {
      margin: 0 0 var(--spacing-md) 0;
    }
  }
  
  .footer-logo svg {
    width: 100%;
    height: 100%;
    display: block;
  }
  
  .copyright {
    font-family: var(--font-pixel);
    font-size: 0.625rem;
    color: var(--color-text);
    margin-bottom: var(--spacing-sm);
  }
  
  .original {
    font-size: 0.875rem;
    color: var(--color-text);
    opacity: 0.8;
    margin: 0;
  }
  
  /* Links Section */
  .footer-links {
    text-align: center;
  }
  
  @media (min-width: 768px) {
    .footer-links {
      text-align: left;
    }
  }
  
  .links-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }
  
  .footer-link {
    display: inline-block;
    font-family: var(--font-pixel);
    font-size: 0.625rem;
    color: var(--color-text);
    text-decoration: none;
    padding: var(--spacing-xs) 0;
    transition: all 0.2s ease;
  }
  
  .footer-link:hover {
    color: var(--color-primary);
    transform: translateX(4px);
  }
  
  /* Social Section */
  .footer-social {
    text-align: center;
  }
  
  @media (min-width: 768px) {
    .footer-social {
      text-align: left;
    }
  }
  
  .social-title {
    font-family: var(--font-pixel);
    font-size: 0.625rem;
    color: var(--color-text);
    margin-bottom: var(--spacing-md);
  }
  
  .social-icons {
    display: flex;
    justify-content: center;
    gap: var(--spacing-md);
  }
  
  @media (min-width: 768px) {
    .social-icons {
      justify-content: flex-start;
    }
  }
  
  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background-color: var(--color-white);
    border: 3px solid var(--color-border);
    box-shadow: 3px 3px 0 var(--color-border);
    transition: all 0.1s ease;
  }
  
  .social-link:hover {
    background-color: var(--color-primary);
    transform: translate(2px, 2px);
    box-shadow: 1px 1px 0 var(--color-border);
  }
  
  .social-link:hover .social-icon {
    color: var(--color-white);
  }
  
  .social-icon {
    width: 20px;
    height: 20px;
    color: var(--color-text);
    transition: color 0.2s ease;
  }
  
  .social-icon svg {
    width: 100%;
    height: 100%;
  }
  
  /* Bottom Bar */
  .footer-bottom {
    border-top: 2px solid var(--color-border);
    padding: var(--spacing-md) 0;
    text-align: center;
  }
  
  .made-with {
    font-family: var(--font-pixel);
    font-size: 0.5rem;
    color: var(--color-text);
    opacity: 0.6;
    margin: 0;
  }
  
  .heart,
  .beads {
    display: inline-block;
    animation: bounce 1s ease infinite;
  }
  
  .heart {
    animation-delay: 0s;
  }
  
  .beads {
    animation-delay: 0.5s;
  }
  
  @keyframes bounce {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-3px);
    }
  }
  
  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .pixel,
    .heart,
    .beads {
      animation: none;
    }
    
    .footer-link:hover {
      transform: none;
    }
  }
</style>

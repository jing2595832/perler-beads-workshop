---
export interface Props {
  currentLang?: 'zh' | 'en' | 'ja';
}

const { currentLang = 'zh' } = Astro.props;

const footerData = {
  zh: {
    copyright: '© 2024 拼豆豆工坊',
    original: '原创内容 · 手工制作 · 像素艺术',
    links: {
      about: '关于我们',
      contact: '联系我们',
      privacy: '隐私政策',
      terms: '使用条款'
    },

  },
  en: {
    copyright: '© 2024 Perler Beads Workshop',
    original: 'Original Content · Handmade · Pixel Art',
    links: {
      about: 'About Us',
      contact: 'Contact',
      privacy: 'Privacy Policy',
      terms: 'Terms of Use'
    },

  },
  ja: {
    copyright: '© 2024 アイロンビーズ工房',
    original: 'オリジナルコンテンツ · ハンドメイド · ドット絵',
    links: {
      about: '私たちについて',
      contact: 'お問い合わせ',
      privacy: 'プライバシーポリシー',
      terms: '利用規約'
    },

  }
};

const content = footerData[currentLang];

const footerLinks = [
  { label: content.links.about, href: '/about' },
  { label: content.links.contact, href: '/contact' },
  { label: content.links.privacy, href: '/privacy' },
  { label: content.links.terms, href: '/terms' }
];
---

<footer class="footer">
  <div class="container">
    <!-- Pixel Art Decoration -->
    <div class="pixel-decoration">
      <div class="pixel-row">
        <span class="pixel" style="--color: #FF6B6B;"></span>
        <span class="pixel" style="--color: #4ECDC4;"></span>
        <span class="pixel" style="--color: #FFE66D;"></span>
        <span class="pixel" style="--color: #FF6B6B;"></span>
        <span class="pixel" style="--color: #4ECDC4;"></span>
        <span class="pixel" style="--color: #FFE66D;"></span>
        <span class="pixel" style="--color: #FF6B6B;"></span>
        <span class="pixel" style="--color: #4ECDC4;"></span>
        <span class="pixel" style="--color: #FFE66D;"></span>
        <span class="pixel" style="--color: #FF6B6B;"></span>
        <span class="pixel" style="--color: #4ECDC4;"></span>
        <span class="pixel" style="--color: #FFE66D;"></span>
      </div>
    </div>
    
    <div class="footer-content">
      <!-- Brand Section -->
      <div class="footer-brand">
        <div class="footer-logo">
          <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="4" y="4" width="6" height="6" fill="#FF6B6B"/>
            <rect x="12" y="4" width="6" height="6" fill="#4ECDC4"/>
            <rect x="20" y="4" width="6" height="6" fill="#FFE66D"/>
            <rect x="4" y="12" width="6" height="6" fill="#4ECDC4"/>
            <rect x="12" y="12" width="6" height="6" fill="#FF6B6B"/>
            <rect x="20" y="12" width="6" height="6" fill="#4ECDC4"/>
            <rect x="4" y="20" width="6" height="6" fill="#FFE66D"/>
            <rect x="12" y="20" width="6" height="6" fill="#4ECDC4"/>
            <rect x="20" y="20" width="6" height="6" fill="#FF6B6B"/>
          </svg>
        </div>
        <p class="copyright">{content.copyright}</p>
        <p class="original">{content.original}</p>
      </div>
      
      <!-- Links Section -->
      <nav class="footer-links" aria-label="Footer navigation">
        <ul class="links-list">
          {footerLinks.map((link) => (
            <li class="link-item">
              <a href={link.href} class="footer-link">{link.label}</a>
            </li>
          ))}
        </ul>
      </nav>
      

    </div>
    
    <!-- Bottom Bar -->
    <div class="footer-bottom">
      <p class="made-with">
        Made with 
        <span class="heart">❤️</span> 
        & 
        <span class="beads">🎨</span>
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-white);
    border-top: var(--border-width) solid var(--color-border);
    margin-top: auto;
  }
  
  /* Pixel Decoration */
  .pixel-decoration {
    padding: var(--spacing-lg) 0;
    display: flex;
    justify-content: center;
    border-bottom: 2px dashed var(--color-border);
  }
  
  .pixel-row {
    display: flex;
    gap: 4px;
  }
  
  .pixel {
    width: 16px;
    height: 16px;
    background-color: var(--color);
    border: 2px solid var(--color-border);
    animation: pixelPulse 2s ease-in-out infinite;
  }
  
  .pixel:nth-child(1) { animation-delay: 0s; }
  .pixel:nth-child(2) { animation-delay: 0.1s; }
  .pixel:nth-child(3) { animation-delay: 0.2s; }
  .pixel:nth-child(4) { animation-delay: 0.3s; }
  .pixel:nth-child(5) { animation-delay: 0.4s; }
  .pixel:nth-child(6) { animation-delay: 0.5s; }
  .pixel:nth-child(7) { animation-delay: 0.6s; }
  .pixel:nth-child(8) { animation-delay: 0.7s; }
  .pixel:nth-child(9) { animation-delay: 0.8s; }
  .pixel:nth-child(10) { animation-delay: 0.9s; }
  .pixel:nth-child(11) { animation-delay: 1s; }
  .pixel:nth-child(12) { animation-delay: 1.1s; }
  
  @keyframes pixelPulse {
    0%, 100% {
      transform: scale(1);
      opacity: 1;
    }
    50% {
      transform: scale(0.85);
      opacity: 0.7;
    }
  }
  
  /* Footer Content */
  .footer-content {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-xl);
    padding: var(--spacing-xl) 0;
  }
  
  @media (min-width: 768px) {
    .footer-content {
      grid-template-columns: 2fr 1fr;
      align-items: start;
    }
  }
  
  /* Brand Section */
  .footer-brand {
    text-align: center;
  }
  
  @media (min-width: 768px) {
    .footer-brand {
      text-align: left;
    }
  }
  
  .footer-logo {
    width: 48px;
    height: 48px;
    margin: 0 auto var(--spacing-md);
    border: 3px solid var(--color-border);
    background-color: var(--color-white);
  }
  
  @media (min-width: 768px) {
    .footer-logo {
      margin: 0 0 var(--spacing-md) 0;
    }
  }
  
  .footer-logo svg {
    width: 100%;
    height: 100%;
    display: block;
  }
  
  .copyright {
    font-family: var(--font-pixel);
    font-size: 0.625rem;
    color: var(--color-text);
    margin-bottom: var(--spacing-sm);
  }
  
  .original {
    font-size: 0.875rem;
    color: var(--color-text);
    opacity: 0.8;
    margin: 0;
  }
  
  /* Links Section */
  .footer-links {
    text-align: center;
  }
  
  @media (min-width: 768px) {
    .footer-links {
      text-align: left;
    }
  }
  
  .links-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }
  
  .footer-link {
    display: inline-block;
    font-family: var(--font-pixel);
    font-size: 0.625rem;
    color: var(--color-text);
    text-decoration: none;
    padding: var(--spacing-xs) 0;
    transition: all 0.2s ease;
  }
  
  .footer-link:hover {
    color: var(--color-primary);
    transform: translateX(4px);
  }
  
  /* Bottom Bar */
  .footer-bottom {
    border-top: 2px solid var(--color-border);
    padding: var(--spacing-md) 0;
    text-align: center;
  }
  
  .made-with {
    font-family: var(--font-pixel);
    font-size: 0.5rem;
    color: var(--color-text);
    opacity: 0.6;
    margin: 0;
  }
  
  .heart,
  .beads {
    display: inline-block;
    animation: bounce 1s ease infinite;
  }
  
  .heart {
    animation-delay: 0s;
  }
  
  .beads {
    animation-delay: 0.5s;
  }
  
  @keyframes bounce {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-3px);
    }
  }
  
  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .pixel,
    .heart,
    .beads {
      animation: none;
    }
    
    .footer-link:hover {
      transform: none;
    }
  }
</style>

---
import type { Pattern } from '../data/patterns';

interface Props {
  pattern: Pattern;
}

const { pattern } = Astro.props;

// 根据难度获取标签样式
function getDifficultyStyle(level: number): string {
  if (level <= 2) {
    return 'easy';
  } else if (level === 3) {
    return 'medium';
  } else {
    return 'hard';
  }
}

const difficultyClass = getDifficultyStyle(pattern.difficulty);
const difficultyLabel = `难度 ${pattern.difficulty}`;
---

<a
  href={`/patterns/${pattern.id}`}
  class="pattern-card"
>
  {/* 缩略图区域 */}
  <div class="pattern-thumbnail">
    <img
      src={`/patterns/${pattern.filename}`}
      alt={pattern.name}
      class="pattern-image"
      loading="lazy"
    />
  </div>

  {/* 信息区域 */}
  <div class="pattern-info">
    {/* 图纸名称 */}
    <h3 class="pattern-name">
      {pattern.name}
    </h3>

    {/* 标签行 */}
    <div class="pattern-tags">
      {/* 难度标签 */}
      <span class={`difficulty-tag ${difficultyClass}`}>
        {difficultyLabel}
      </span>

      {/* 尺寸信息 */}
      <span class="size-tag">
        {pattern.size.width}×{pattern.size.height}
      </span>
    </div>
  </div>
</a>

<style>
  .pattern-card {
    display: block;
    background-color: var(--color-white);
    border: var(--border-width) solid var(--color-border);
    box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--color-shadow);
    transition: all 0.2s ease;
    text-decoration: none;
    overflow: hidden;
  }

  .pattern-card:hover {
    transform: translate(-2px, -2px);
    box-shadow: calc(var(--shadow-offset) + 2px) calc(var(--shadow-offset) + 2px) 0 var(--color-shadow);
  }

  .pattern-card:active {
    transform: translate(var(--shadow-offset), var(--shadow-offset));
    box-shadow: 0 0 0 var(--color-shadow);
  }

  /* 缩略图区域 */
  .pattern-thumbnail {
    aspect-ratio: 1;
    overflow: hidden;
    border-bottom: var(--border-width) solid var(--color-border);
    background-color: var(--color-background);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pattern-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    image-rendering: pixelated;
    transition: transform 0.3s ease;
  }

  .pattern-card:hover .pattern-image {
    transform: scale(1.05);
  }

  /* 信息区域 */
  .pattern-info {
    padding: var(--spacing-md);
  }

  .pattern-name {
    font-family: var(--font-pixel);
    font-size: 0.75rem;
    color: var(--color-text);
    margin-bottom: var(--spacing-sm);
    line-height: 1.4;
  }

  .pattern-tags {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-sm);
  }

  .difficulty-tag {
    display: inline-block;
    padding: var(--spacing-xs) var(--spacing-sm);
    font-family: var(--font-pixel);
    font-size: 0.5rem;
    border-radius: 0;
    border: 2px solid var(--color-border);
  }

  .difficulty-tag.easy {
    background-color: #4ECDC4;
    color: var(--color-white);
  }

  .difficulty-tag.medium {
    background-color: var(--color-accent);
    color: var(--color-text);
  }

  .difficulty-tag.hard {
    background-color: var(--color-primary);
    color: var(--color-white);
  }

  .size-tag {
    font-family: var(--font-pixel);
    font-size: 0.5rem;
    color: var(--color-text);
    opacity: 0.7;
  }
</style>

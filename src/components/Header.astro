---
import LanguageSwitcher from './LanguageSwitcher';

export interface Props {
  currentLang?: 'zh' | 'en' | 'ja';
  activeNav?: 'home' | 'patterns' | 'designer' | 'tutorials' | 'community';
}

const { 
  currentLang = 'zh',
  activeNav = 'home'
} = Astro.props;

const navData = {
  zh: {
    siteName: '拼豆豆工坊',
    nav: [
      { id: 'home', label: '首页', href: '/' },
      { id: 'patterns', label: '图纸库', href: '/patterns' },
      { id: 'designer', label: '设计工具', href: '/designer' },
      { id: 'tutorials', label: '教程', href: '/tutorials' },
      { id: 'community', label: '社区', href: '/community' }
    ]
  },
  en: {
    siteName: 'Perler Workshop',
    nav: [
      { id: 'home', label: 'Home', href: '/' },
      { id: 'patterns', label: 'Patterns', href: '/patterns' },
      { id: 'designer', label: 'Designer', href: '/designer' },
      { id: 'tutorials', label: 'Tutorials', href: '/tutorials' },
      { id: 'community', label: 'Community', href: '/community' }
    ]
  },
  ja: {
    siteName: 'ビーズ工房',
    nav: [
      { id: 'home', label: 'ホーム', href: '/' },
      { id: 'patterns', label: '図案集', href: '/patterns' },
      { id: 'designer', label: 'デザイナー', href: '/designer' },
      { id: 'tutorials', label: 'チュートリアル', href: '/tutorials' },
      { id: 'community', label: 'コミュニティ', href: '/community' }
    ]
  }
};

const content = navData[currentLang];
---

<header class="header">
  <div class="container header-container">
    <!-- Logo -->
    <a href="/" class="logo">
      <div class="logo-icon">
        <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <!-- Pixel Bead Grid -->
          <rect x="4" y="4" width="6" height="6" fill="#FF6B6B"/>
          <rect x="12" y="4" width="6" height="6" fill="#4ECDC4"/>
          <rect x="20" y="4" width="6" height="6" fill="#FFE66D"/>
          <rect x="4" y="12" width="6" height="6" fill="#4ECDC4"/>
          <rect x="12" y="12" width="6" height="6" fill="#FF6B6B"/>
          <rect x="20" y="12" width="6" height="6" fill="#4ECDC4"/>
          <rect x="4" y="20" width="6" height="6" fill="#FFE66D"/>
          <rect x="12" y="20" width="6" height="6" fill="#4ECDC4"/>
          <rect x="20" y="20" width="6" height="6" fill="#FF6B6B"/>
        </svg>
      </div>
      <span class="logo-text">{content.siteName}</span>
    </a>
    
    <!-- Navigation -->
    <nav class="nav" aria-label="Main navigation">
      <ul class="nav-list">
        {content.nav.map((item) => (
          <li class="nav-item">
            <a 
              href={item.href} 
              class={`nav-link ${activeNav === item.id ? 'active' : ''}`}
              aria-current={activeNav === item.id ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
    
    <!-- Language Switcher -->
    <div class="language-section">
      <LanguageSwitcher currentLang={currentLang} client:load />
    </div>
    
    <!-- Mobile Menu Button -->
    <button 
      class="mobile-menu-btn" 
      aria-label="Toggle menu"
      aria-expanded="false"
      id="mobile-menu-toggle"
    >
      <span class="hamburger"></span>
      <span class="hamburger"></span>
      <span class="hamburger"></span>
    </button>
  </div>
  
  <!-- Mobile Navigation -->
  <nav class="mobile-nav" id="mobile-nav" aria-label="Mobile navigation">
    <ul class="mobile-nav-list">
      {content.nav.map((item) => (
        <li class="mobile-nav-item">
          <a 
            href={item.href} 
            class={`mobile-nav-link ${activeNav === item.id ? 'active' : ''}`}
            aria-current={activeNav === item.id ? 'page' : undefined}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<style>
  .header {
    background-color: var(--color-white);
    border-bottom: var(--border-width) solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 0 rgba(44, 62, 80, 0.1);
  }
  
  .header-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 70px;
    gap: var(--spacing-md);
  }
  
  /* Logo */
  .logo {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    text-decoration: none;
    flex-shrink: 0;
  }
  
  .logo-icon {
    width: 40px;
    height: 40px;
    border: 2px solid var(--color-border);
    background-color: var(--color-white);
  }
  
  .logo-icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }
  
  .logo-text {
    font-family: var(--font-pixel);
    font-size: 0.875rem;
    color: var(--color-text);
    line-height: 1.2;
  }
  
  .logo:hover .logo-text {
    color: var(--color-primary);
  }
  
  /* Navigation */
  .nav {
    display: none;
  }
  
  .nav-list {
    display: flex;
    list-style: none;
    gap: var(--spacing-xs);
    margin: 0;
    padding: 0;
  }
  
  .nav-link {
    display: block;
    padding: var(--spacing-sm) var(--spacing-md);
    font-family: var(--font-pixel);
    font-size: 0.625rem;
    color: var(--color-text);
    text-decoration: none;
    border: 2px solid transparent;
    transition: all 0.2s ease;
    white-space: nowrap;
  }
  
  .nav-link:hover {
    color: var(--color-primary);
    background-color: rgba(255, 107, 107, 0.1);
  }
  
  .nav-link.active {
    color: var(--color-white);
    background-color: var(--color-primary);
    border-color: var(--color-border);
    box-shadow: 2px 2px 0 var(--color-border);
  }
  
  /* Language Section */
  .language-section {
    display: flex;
    align-items: center;
    margin-left: auto;
  }
  
  /* Mobile Menu Button */
  .mobile-menu-btn {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 40px;
    height: 40px;
    gap: 5px;
    background-color: var(--color-white);
    border: var(--border-width) solid var(--color-border);
    box-shadow: 2px 2px 0 var(--color-border);
    cursor: pointer;
    transition: all 0.1s ease;
  }
  
  .mobile-menu-btn:hover {
    background-color: var(--color-background);
  }
  
  .mobile-menu-btn:active {
    transform: translate(2px, 2px);
    box-shadow: 0 0 0 var(--color-border);
  }
  
  .hamburger {
    display: block;
    width: 20px;
    height: 3px;
    background-color: var(--color-text);
    transition: all 0.3s ease;
  }
  
  .mobile-menu-btn[aria-expanded="true"] .hamburger:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }
  
  .mobile-menu-btn[aria-expanded="true"] .hamburger:nth-child(2) {
    opacity: 0;
  }
  
  .mobile-menu-btn[aria-expanded="true"] .hamburger:nth-child(3) {
    transform: rotate(-45deg) translate(6px, -6px);
  }
  
  /* Mobile Navigation */
  .mobile-nav {
    display: none;
    background-color: var(--color-white);
    border-top: var(--border-width) solid var(--color-border);
    border-bottom: var(--border-width) solid var(--color-border);
  }
  
  .mobile-nav.open {
    display: block;
  }
  
  .mobile-nav-list {
    list-style: none;
    margin: 0;
    padding: var(--spacing-md);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }
  
  .mobile-nav-link {
    display: block;
    padding: var(--spacing-md);
    font-family: var(--font-pixel);
    font-size: 0.75rem;
    color: var(--color-text);
    text-decoration: none;
    border: 2px solid var(--color-border);
    background-color: var(--color-white);
    text-align: center;
    transition: all 0.2s ease;
  }
  
  .mobile-nav-link:hover {
    background-color: var(--color-primary);
    color: var(--color-white);
  }
  
  .mobile-nav-link.active {
    background-color: var(--color-primary);
    color: var(--color-white);
    box-shadow: 3px 3px 0 var(--color-border);
  }
  
  /* Desktop Styles */
  @media (min-width: 1024px) {
    .nav {
      display: block;
    }
    
    .mobile-menu-btn {
      display: none;
    }
    
    .mobile-nav {
      display: none !important;
    }
    
    .logo-text {
      font-size: 1rem;
    }
  }
  
  @media (min-width: 768px) and (max-width: 1023px) {
    .nav {
      display: block;
    }
    
    .nav-link {
      font-size: 0.5rem;
      padding: var(--spacing-sm);
    }
    
    .mobile-menu-btn {
      display: none;
    }
    
    .mobile-nav {
      display: none !important;
    }
  }
</style>

<script>
  // Mobile menu toggle
  const menuToggle = document.getElementById('mobile-menu-toggle');
  const mobileNav = document.getElementById('mobile-nav');
  
  if (menuToggle && mobileNav) {
    menuToggle.addEventListener('click', () => {
      const isExpanded = menuToggle.getAttribute('aria-expanded') === 'true';
      menuToggle.setAttribute('aria-expanded', (!isExpanded).toString());
      mobileNav.classList.toggle('open');
    });
    
    // Close mobile menu when clicking on a link
    const mobileLinks = mobileNav.querySelectorAll('a');
    mobileLinks.forEach(link => {
      link.addEventListener('click', () => {
        menuToggle.setAttribute('aria-expanded', 'false');
        mobileNav.classList.remove('open');
      });
    });
  }
</script>

---
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { tutorialsData, type Tutorial } from '../../data/tutorials';

// 生成静态路径
export async function getStaticPaths() {
  const ids = Object.keys(tutorialsData);
  return ids.map((id) => ({
    params: { id },
    props: { tutorial: tutorialsData[id] }
  }));
}

interface Props {
  tutorial: Tutorial;
}

const { tutorial } = Astro.props;

// 相关教程推荐
const allTutorials = Object.values(tutorialsData);
const relatedTutorials = allTutorials
  .filter(t => t.id !== tutorial.id)
  .slice(0, 3);
---

<Layout title={`${tutorial.title} - 教程`} description={tutorial.description}>
  <Header activeNav="tutorials" />
  
  <main class="tutorial-detail-page">
    <div class="container">
      <!-- 面包屑导航 -->
      <nav class="breadcrumb">
        <a href="/">首页</a>
        <span class="separator">&gt;</span>
        <a href="/tutorials">教程</a>
        <span class="separator">&gt;</span>
        <span class="current">{tutorial.title}</span>
      </nav>
      
      <!-- 教程头部 -->
      <header class="tutorial-header" style={`--accent-color: ${tutorial.color}`}>
        <div class="header-icon">{tutorial.icon}</div>
        <div class="header-content">
          <h1 class="tutorial-title">{tutorial.title}</h1>
          <p class="tutorial-title-en">{tutorial.titleEn}</p>
          <p class="tutorial-desc">{tutorial.description}</p>
          <div class="tutorial-meta">
            <span class="meta-item level">
              <span class="meta-icon">📊</span>
              {tutorial.level}
            </span>
            <span class="meta-item time">
              <span class="meta-icon">⏱️</span>
              {tutorial.time}
            </span>
          </div>
        </div>
      </header>
      
      <!-- 主要内容 -->
      <div class="tutorial-content">
        <article class="content-article" set:html={tutorial.content} />
        
        <!-- 学习进度提示 -->
        <div class="progress-tip">
          <div class="tip-icon">✨</div>
          <div class="tip-content">
            <h3>完成本教程？</h3>
            <p>恭喜你掌握了新技能！继续探索更多教程吧。</p>
            <a href="/tutorials" class="pixel-btn">查看更多教程</a>
          </div>
        </div>
      </div>
      
      <!-- 相关教程推荐 -->
      <section class="related-section">
        <h2 class="section-title">
          <span class="title-icon">📖</span>
          相关教程
        </h2>
        <div class="related-grid">
          {relatedTutorials.map((related) => (
            <a href={`/tutorials/${related.id}`} class="related-card" style={`--card-color: ${related.color}`}>
              <div class="card-header">
                <span class="card-icon">{related.icon}</span>
                <span class="card-level">{related.level}</span>
              </div>
              <h3 class="card-title">{related.title}</h3>
              <p class="card-desc">{related.description}</p>
              <div class="card-meta">
                <span class="meta-time">⏱️ {related.time}</span>
              </div>
            </a>
          ))}
        </div>
      </section>
      
      <!-- 快捷导航 -->
      <div class="quick-nav">
        <a href="/patterns" class="nav-item">
          <span class="nav-icon">📚</span>
          <span class="nav-text">浏览图纸库</span>
        </a>
        <a href="/design" class="nav-item">
          <span class="nav-icon">🎨</span>
          <span class="nav-text">开始创作</span>
        </a>
        <a href="/community" class="nav-item">
          <span class="nav-icon">👥</span>
          <span class="nav-text">分享作品</span>
        </a>
      </div>
    </div>
  </main>
  
  <Footer />
</Layout>

<style>
  .tutorial-detail-page {
    padding: var(--spacing-xl) 0;
    background: linear-gradient(180deg, var(--color-white) 0%, var(--color-background) 100%);
    min-height: calc(100vh - 200px);
  }
  
  /* 面包屑 */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-xl);
    font-family: var(--font-pixel);
    font-size: 0.625rem;
  }
  
  .breadcrumb a {
    color: var(--color-primary);
    text-decoration: none;
    padding: var(--spacing-xs) var(--spacing-sm);
    border: 2px solid var(--color-primary);
    background: var(--color-white);
    transition: all 0.2s;
  }
  
  .breadcrumb a:hover {
    background: var(--color-primary);
    color: var(--color-white);
  }
  
  .breadcrumb .separator {
    color: var(--color-text);
    opacity: 0.5;
  }
  
  .breadcrumb .current {
    padding: var(--spacing-xs) var(--spacing-sm);
    background: var(--color-accent);
    border: 2px solid var(--color-border);
  }
  
  /* 教程头部 */
  .tutorial-header {
    display: flex;
    gap: var(--spacing-xl);
    padding: var(--spacing-xl);
    background: var(--color-white);
    border: 4px solid var(--color-border);
    box-shadow: 8px 8px 0 var(--color-border);
    margin-bottom: var(--spacing-xl);
  }
  
  @media (max-width: 768px) {
    .tutorial-header {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
  }
  
  .header-icon {
    font-size: 5rem;
    flex-shrink: 0;
    animation: bounce 2s ease-in-out infinite;
  }
  
  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
  
  .tutorial-title {
    font-family: var(--font-pixel);
    font-size: clamp(1.5rem, 4vw, 2rem);
    color: var(--accent-color);
    margin-bottom: var(--spacing-xs);
  }
  
  .tutorial-title-en {
    font-size: 0.875rem;
    color: var(--color-text);
    opacity: 0.6;
    margin-bottom: var(--spacing-sm);
  }
  
  .tutorial-desc {
    font-size: 1rem;
    color: var(--color-text);
    opacity: 0.8;
    margin-bottom: var(--spacing-md);
  }
  
  .tutorial-meta {
    display: flex;
    gap: var(--spacing-lg);
  }
  
  .meta-item {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
    font-family: var(--font-pixel);
    font-size: 0.625rem;
    padding: var(--spacing-xs) var(--spacing-sm);
    background: var(--color-background);
    border: 2px solid var(--color-border);
  }
  
  .meta-item.level {
    background: var(--accent-color);
    color: var(--color-white);
  }
  
  /* 内容区域 */
  .tutorial-content {
    background: var(--color-white);
    border: 3px solid var(--color-border);
    padding: var(--spacing-xl);
    margin-bottom: var(--spacing-xl);
  }
  
  .content-article {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--color-text);
  }
  
  .content-article :global(h2) {
    font-family: var(--font-pixel);
    font-size: 1.25rem;
    color: var(--color-primary);
    margin: var(--spacing-xl) 0 var(--spacing-md);
    padding-bottom: var(--spacing-sm);
    border-bottom: 3px solid var(--color-border);
  }
  
  .content-article :global(h3) {
    font-family: var(--font-pixel);
    font-size: 1rem;
    color: var(--color-text);
    margin: var(--spacing-lg) 0 var(--spacing-sm);
  }
  
  .content-article :global(p) {
    margin-bottom: var(--spacing-md);
  }
  
  .content-article :global(ul),
  .content-article :global(ol) {
    margin-bottom: var(--spacing-md);
    padding-left: var(--spacing-xl);
  }
  
  .content-article :global(li) {
    margin-bottom: var(--spacing-xs);
  }
  
  .content-article :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: var(--spacing-md) 0;
  }
  
  .content-article :global(th),
  .content-article :global(td) {
    padding: var(--spacing-sm);
    border: 2px solid var(--color-border);
    text-align: left;
  }
  
  .content-article :global(th) {
    background: var(--color-primary);
    color: var(--color-white);
    font-family: var(--font-pixel);
    font-size: 0.75rem;
  }
  
  .content-article :global(code) {
    background: var(--color-background);
    padding: 2px 6px;
    font-family: monospace;
    font-size: 0.875em;
  }
  
  .content-article :global(strong) {
    color: var(--color-primary);
  }
  
  /* 进度提示 */
  .progress-tip {
    display: flex;
    align-items: center;
    gap: var(--spacing-lg);
    padding: var(--spacing-lg);
    background: linear-gradient(135deg, rgba(78, 205, 196, 0.1) 0%, rgba(255, 230, 109, 0.1) 100%);
    border: 3px dashed var(--color-secondary);
    margin-top: var(--spacing-xl);
  }
  
  .tip-icon {
    font-size: 3rem;
    flex-shrink: 0;
  }
  
  .tip-content h3 {
    font-family: var(--font-pixel);
    font-size: 0.875rem;
    margin-bottom: var(--spacing-xs);
  }
  
  .tip-content p {
    font-size: 0.875rem;
    opacity: 0.8;
    margin-bottom: var(--spacing-sm);
  }
  
  .pixel-btn {
    display: inline-block;
    padding: var(--spacing-sm) var(--spacing-lg);
    font-family: var(--font-pixel);
    font-size: 0.625rem;
    background: var(--color-primary);
    color: var(--color-white);
    border: 3px solid var(--color-border);
    box-shadow: 4px 4px 0 var(--color-border);
    text-decoration: none;
    transition: all 0.1s;
  }
  
  .pixel-btn:hover {
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0 var(--color-border);
  }
  
  /* 相关教程 */
  .related-section {
    margin-bottom: var(--spacing-xl);
  }
  
  .section-title {
    font-family: var(--font-pixel);
    font-size: 1.25rem;
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-lg);
  }
  
  .related-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: var(--spacing-md);
  }
  
  @media (min-width: 640px) {
    .related-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  
  .related-card {
    display: flex;
    flex-direction: column;
    padding: var(--spacing-lg);
    background: var(--color-white);
    border: 3px solid var(--color-border);
    box-shadow: 4px 4px 0 var(--color-border);
    text-decoration: none;
    color: var(--color-text);
    transition: all 0.2s;
  }
  
  .related-card:hover {
    transform: translate(-4px, -4px);
    box-shadow: 8px 8px 0 var(--card-color);
    border-color: var(--card-color);
  }
  
  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--spacing-sm);
  }
  
  .card-icon {
    font-size: 2rem;
  }
  
  .card-level {
    font-family: var(--font-pixel);
    font-size: 0.5rem;
    padding: 4px 8px;
    background: var(--card-color);
    color: white;
    border: 2px solid var(--color-border);
  }
  
  .card-title {
    font-family: var(--font-pixel);
    font-size: 0.875rem;
    margin-bottom: var(--spacing-xs);
  }
  
  .card-desc {
    font-size: 0.75rem;
    opacity: 0.8;
    margin-bottom: var(--spacing-sm);
    flex-grow: 1;
  }
  
  .card-meta {
    font-size: 0.625rem;
    opacity: 0.7;
  }
  
  /* 快捷导航 */
  .quick-nav {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-md);
  }
  
  .nav-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-lg);
    background: var(--color-white);
    border: 3px solid var(--color-border);
    box-shadow: 4px 4px 0 var(--color-border);
    text-decoration: none;
    color: var(--color-text);
    transition: all 0.2s;
  }
  
  .nav-item:hover {
    transform: translateY(-4px);
    box-shadow: 6px 6px 0 var(--color-primary);
    border-color: var(--color-primary);
  }
  
  .nav-icon {
    font-size: 2rem;
  }
  
  .nav-text {
    font-family: var(--font-pixel);
    font-size: 0.625rem;
  }
</style>

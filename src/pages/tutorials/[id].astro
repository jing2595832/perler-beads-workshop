---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export function getStaticPaths() {
  // 暂时无教程详情数据，返回空数组
  return [];
}

const { id } = Astro.params;
---

<Layout title="教程详情" description="拼豆教程详情页">
  <Header activeNav="tutorials" />

  <main>
    <!-- 面包屑 -->
    <nav class="breadcrumb" aria-label="面包屑导航">
      <div class="container">
        <a href="/tutorials">教程</a>
        <span class="breadcrumb-sep">/</span>
        <span class="breadcrumb-current">{id || '详情'}</span>
      </div>
    </nav>

    <!-- 教程开发中提示 -->
    <section class="coming-soon-section">
      <div class="container">
        <div class="coming-soon-card">
          <div class="coming-soon-icon">🔨</div>
          <h1 class="coming-soon-title">教程开发中</h1>
          <p class="coming-soon-desc">
            这个教程正在精心制作中，敬请期待！
          </p>
          <p class="coming-soon-hint">
            我们正在准备详细的图文教程和视频指导，帮助你掌握拼豆制作的每一个技巧。
          </p>

          <div class="coming-soon-features">
            <div class="feature-item">
              <span class="feature-icon">📖</span>
              <span class="feature-text">详细图文步骤</span>
            </div>
            <div class="feature-item">
              <span class="feature-icon">🎬</span>
              <span class="feature-text">视频教程</span>
            </div>
            <div class="feature-item">
              <span class="feature-icon">💡</span>
              <span class="feature-text">实用技巧</span>
            </div>
            <div class="feature-item">
              <span class="feature-icon">❓</span>
              <span class="feature-text">常见问题</span>
            </div>
          </div>

          <div class="coming-soon-actions">
            <a href="/tutorials" class="pixel-btn">
              <span class="btn-icon">←</span>
              返回教程列表
            </a>
            <a href="/patterns" class="pixel-btn secondary">
              <span class="btn-icon">📚</span>
              浏览图纸库
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* 面包屑 */
  .breadcrumb {
    padding: var(--spacing-md) 0;
    background-color: var(--color-white);
    border-bottom: 2px solid var(--color-border);
    font-family: var(--font-pixel);
    font-size: 0.5rem;
  }

  .breadcrumb .container {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
  }

  .breadcrumb a {
    color: var(--color-secondary);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: var(--color-primary);
  }

  .breadcrumb-sep {
    color: var(--color-text);
    opacity: 0.4;
  }

  .breadcrumb-current {
    color: var(--color-text);
    opacity: 0.7;
  }

  /* 开发中区域 */
  .coming-soon-section {
    padding: var(--spacing-2xl) 0;
    background-color: var(--color-background);
    min-height: 60vh;
    display: flex;
    align-items: center;
  }

  .coming-soon-card {
    background-color: var(--color-white);
    border: var(--border-width) solid var(--color-border);
    box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--color-shadow);
    padding: var(--spacing-2xl) var(--spacing-lg);
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
    width: 100%;
  }

  .coming-soon-icon {
    font-size: 4rem;
    margin-bottom: var(--spacing-lg);
    display: block;
    animation: bounce 2s ease infinite;
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  .coming-soon-title {
    font-family: var(--font-pixel);
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    color: var(--color-text);
    margin-bottom: var(--spacing-md);
  }

  .coming-soon-desc {
    font-size: 1.125rem;
    color: var(--color-text);
    opacity: 0.8;
    margin-bottom: var(--spacing-sm);
  }

  .coming-soon-hint {
    font-size: 0.9375rem;
    color: var(--color-text);
    opacity: 0.6;
    margin-bottom: var(--spacing-xl);
    line-height: 1.6;
  }

  /* 功能预览 */
  .coming-soon-features {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-xl);
  }

  .feature-item {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
    padding: var(--spacing-sm);
    background-color: var(--color-background);
    border: 2px solid var(--color-border);
    box-shadow: 2px 2px 0 var(--color-border);
  }

  .feature-icon {
    font-size: 1.25rem;
  }

  .feature-text {
    font-family: var(--font-pixel);
    font-size: 0.5rem;
    color: var(--color-text);
  }

  /* 操作按钮 */
  .coming-soon-actions {
    display: flex;
    gap: var(--spacing-md);
    justify-content: center;
    flex-wrap: wrap;
  }

  .coming-soon-actions .pixel-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-sm);
    text-decoration: none;
  }

  .btn-icon {
    font-size: 1em;
  }

  /* 响应式 */
  @media (max-width: 480px) {
    .coming-soon-features {
      grid-template-columns: 1fr;
    }
  }
</style>

---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const tutorials = [
  {
    id: 'basics',
    title: '拼豆入门基础',
    description: '从零开始学习拼豆，了解材料、工具和基本技巧',
    icon: '🌱',
    level: '初级',
    steps: 5,
    time: '30分钟',
    color: '#4ECDC4'
  },
  {
    id: 'ironing',
    title: '熨烫技巧详解',
    description: '掌握正确的熨烫方法，让作品平整美观',
    icon: '🔥',
    level: '中级',
    steps: 8,
    time: '45分钟',
    color: '#FF6B6B'
  },
  {
    id: 'color-matching',
    title: '颜色搭配指南',
    description: '学习如何选择和搭配颜色，创作出和谐的作品',
    icon: '🎨',
    level: '中级',
    steps: 6,
    time: '40分钟',
    color: '#9B59B6'
  },
  {
    id: '3d-techniques',
    title: '立体拼豆制作',
    description: '进阶技巧：制作立体拼豆作品和可拼接模型',
    icon: '📦',
    level: '高级',
    steps: 12,
    time: '2小时',
    color: '#FF8E53'
  },
  {
    id: 'keychain',
    title: '钥匙扣制作',
    description: '制作实用的拼豆钥匙扣，从设计到成品',
    icon: '🔑',
    level: '初级',
    steps: 4,
    time: '25分钟',
    color: '#5B8DEF'
  },
  {
    id: 'coaster',
    title: '杯垫制作教程',
    description: '制作美观实用的拼豆杯垫，适合初学者',
    icon: '☕',
    level: '初级',
    steps: 5,
    time: '35分钟',
    color: '#45B7D1'
  }
];

const tips = [
  { icon: '💡', title: '选择拼豆', content: '优质拼豆颜色鲜艳、大小均匀，建议选择知名品牌' },
  { icon: '📐', title: '模板使用', content: '使用透明模板板，方便查看图纸和定位' },
  { icon: '🔥', title: '熨烫温度', content: '中低温熨烫，温度过高会导致拼豆变形' },
  { icon: '⏰', title: '冷却时间', content: '熨烫后充分冷却再揭下，避免变形' },
  { icon: '🧹', title: '清洁保养', content: '用湿布轻轻擦拭，避免浸泡' },
  { icon: '🎁', title: '创意应用', content: '可以制作钥匙扣、冰箱贴、杯垫等实用物品' }
];
---

<Layout title="教程" description="学习拼豆制作技巧，从入门到精通">
  <Header activeNav="tutorials" />
  
  <main class="tutorials-page">
    <div class="container">
      <!-- 页面标题 -->
      <div class="page-header">
        <h1 class="page-title">
          <span class="title-icon">📖</span>
          拼豆教程
        </h1>
        <p class="page-desc">从入门到精通，一步步学会拼豆制作</p>
      </div>
      
      <!-- 快速开始 -->
      <section class="quick-start">
        <div class="start-card">
          <div class="start-icon">🚀</div>
          <div class="start-content">
            <h2>新手入门？从这里开始！</h2>
            <p>推荐先学习《拼豆入门基础》，了解材料工具和基本技巧</p>
            <a href="#tutorial-basics" class="pixel-btn primary">
              立即开始
            </a>
          </div>
        </div>
      </section>
      
      <!-- 教程列表 -->
      <section class="tutorials-section">
        <h2 class="section-title">📚 全部教程</h2>
        <div class="tutorials-grid">
          {tutorials.map((tutorial) => (
            <a href={`/tutorials/${tutorial.id}`} class="tutorial-card" style={`--card-color: ${tutorial.color}`} id={`tutorial-${tutorial.id}`}>
              <div class="card-header">
                <span class="card-icon">{tutorial.icon}</span>
                <span class="card-level">{tutorial.level}</span>
              </div>
              <h3 class="card-title">{tutorial.title}</h3>
              <p class="card-desc">{tutorial.description}</p>
              <div class="card-meta">
                <span class="meta-item">
                  <span class="meta-icon">📋</span>
                  {tutorial.steps} 个步骤
                </span>
                <span class="meta-item">
                  <span class="meta-icon">⏱️</span>
                  {tutorial.time}
                </span>
              </div>
            </a>
          ))}
        </div>
      </section>
      
      <!-- 制作技巧 -->
      <section class="tips-section">
        <h2 class="section-title">💡 制作小技巧</h2>
        <div class="tips-grid">
          {tips.map((tip) => (
            <div class="tip-card">
              <span class="tip-icon">{tip.icon}</span>
              <h3 class="tip-title">{tip.title}</h3>
              <p class="tip-content">{tip.content}</p>
            </div>
          ))}
        </div>
      </section>
      
      <!-- 常见问题 -->
      <section class="faq-section">
        <h2 class="section-title">❓ 常见问题</h2>
        <div class="faq-list">
          <details class="faq-item">
            <summary class="faq-question">拼豆需要哪些基础材料？</summary>
            <div class="faq-answer">
              <p>基础材料包括：拼豆（建议5mm规格）、模板板（透明款）、熨斗、烘焙纸/熨烫纸、镊子。初学者可以购买入门套装，包含所有必需品。</p>
            </div>
          </details>
          <details class="faq-item">
            <summary class="faq-question">熨烫时为什么拼豆会变形？</summary>
            <div class="faq-answer">
              <p>变形通常是因为温度过高或熨烫时间过长。建议使用中低温，熨烫时轻轻移动熨斗，不要在一个位置停留太久。不同品牌的拼豆熔点略有不同，需要适当调整。</p>
            </div>
          </details>
          <details class="faq-item">
            <summary class="faq-question">作品完成后如何保存？</summary>
            <div class="faq-answer">
              <p>完成的拼豆作品应避免阳光直射和高温环境，防止褪色和变形。可以用密封袋保存，或用软布包裹防止刮花。如果是钥匙扣等常用物品，建议定期检查连接处。</p>
            </div>
          </details>
          <details class="faq-item">
            <summary class="faq-question">没有熨斗可以用什么代替？</summary>
            <div class="faq-answer">
              <p>可以使用直发夹板代替熨斗，效果类似。但需要注意温度控制和均匀加热。不建议使用微波炉或烤箱，温度难以控制，容易损坏作品。</p>
            </div>
          </details>
        </div>
      </section>
      
      <!-- 需要帮助 -->
      <section class="help-section">
        <div class="help-card">
          <span class="help-icon">🙋</span>
          <h2>还有疑问？</h2>
          <p>如果您有其他问题，欢迎联系我们获取帮助</p>
          <a href="/contact" class="pixel-btn">联系我们</a>
        </div>
      </section>
    </div>
  </main>
  
  <Footer />
</Layout>

<style>
  .tutorials-page {
    padding: var(--spacing-xl) 0;
    background: linear-gradient(180deg, var(--color-white) 0%, var(--color-background) 100%);
    min-height: calc(100vh - 200px);
  }
  
  .page-header {
    text-align: center;
    margin-bottom: var(--spacing-xl);
  }
  
  .page-title {
    font-family: var(--font-pixel);
    font-size: clamp(1.25rem, 4vw, 1.75rem);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-sm);
  }
  
  .title-icon {
    font-size: 1.5em;
  }
  
  .page-desc {
    color: var(--color-text);
    opacity: 0.7;
    margin: 0;
  }
  
  /* 快速开始 */
  .quick-start {
    margin-bottom: var(--spacing-xl);
  }
  
  .start-card {
    display: flex;
    align-items: center;
    gap: var(--spacing-lg);
    padding: var(--spacing-lg);
    background: linear-gradient(135deg, #FFE66D 0%, #FF8E53 100%);
    border: 4px solid var(--color-border);
    box-shadow: 8px 8px 0 var(--color-border);
  }
  
  @media (max-width: 640px) {
    .start-card {
      flex-direction: column;
      text-align: center;
    }
  }
  
  .start-icon {
    font-size: 4rem;
    flex-shrink: 0;
  }
  
  .start-content h2 {
    font-family: var(--font-pixel);
    font-size: 1rem;
    margin: 0 0 var(--spacing-sm) 0;
  }
  
  .start-content p {
    margin: 0 0 var(--spacing-md) 0;
    opacity: 0.9;
  }
  
  .pixel-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-sm) var(--spacing-lg);
    font-family: var(--font-pixel);
    font-size: 0.75rem;
    background: var(--color-white);
    border: 3px solid var(--color-border);
    box-shadow: 4px 4px 0 var(--color-border);
    text-decoration: none;
    color: var(--color-text);
    transition: all 0.1s;
  }
  
  .pixel-btn:hover {
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0 var(--color-border);
  }
  
  .pixel-btn.primary {
    background: var(--color-primary);
    color: var(--color-white);
  }
  
  /* 教程列表 */
  .tutorials-section {
    margin-bottom: var(--spacing-xl);
  }
  
  .section-title {
    font-family: var(--font-pixel);
    font-size: 1.125rem;
    margin-bottom: var(--spacing-lg);
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
  }
  
  .tutorials-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: var(--spacing-md);
  }
  
  @media (min-width: 640px) {
    .tutorials-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media (min-width: 1024px) {
    .tutorials-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  
  .tutorial-card {
    display: flex;
    flex-direction: column;
    padding: var(--spacing-lg);
    background: var(--color-white);
    border: 3px solid var(--color-border);
    box-shadow: 4px 4px 0 var(--color-border);
    text-decoration: none;
    color: var(--color-text);
    transition: all 0.2s;
  }
  
  .tutorial-card:hover {
    transform: translate(-4px, -4px);
    box-shadow: 8px 8px 0 var(--card-color);
    border-color: var(--card-color);
  }
  
  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--spacing-sm);
  }
  
  .card-icon {
    font-size: 2rem;
  }
  
  .card-level {
    font-family: var(--font-pixel);
    font-size: 0.5rem;
    padding: 4px 8px;
    background: var(--card-color);
    color: white;
    border: 2px solid var(--color-border);
  }
  
  .card-title {
    font-family: var(--font-pixel);
    font-size: 0.875rem;
    margin: 0 0 var(--spacing-sm) 0;
  }
  
  .card-desc {
    font-size: 0.875rem;
    opacity: 0.8;
    margin: 0 0 var(--spacing-md) 0;
    flex-grow: 1;
  }
  
  .card-meta {
    display: flex;
    gap: var(--spacing-md);
    font-size: 0.625rem;
    font-family: var(--font-pixel);
  }
  
  .meta-item {
    display: flex;
    align-items: center;
    gap: 4px;
    opacity: 0.7;
  }
  
  .meta-icon {
    font-size: 0.875rem;
  }
  
  /* 技巧区域 */
  .tips-section {
    margin-bottom: var(--spacing-xl);
  }
  
  .tips-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-md);
  }
  
  @media (min-width: 768px) {
    .tips-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  
  .tip-card {
    padding: var(--spacing-md);
    background: var(--color-white);
    border: 3px solid var(--color-border);
    text-align: center;
    transition: all 0.2s;
  }
  
  .tip-card:hover {
    transform: translateY(-4px);
    box-shadow: 4px 4px 0 var(--color-border);
  }
  
  .tip-icon {
    font-size: 2rem;
    display: block;
    margin-bottom: var(--spacing-sm);
  }
  
  .tip-title {
    font-family: var(--font-pixel);
    font-size: 0.625rem;
    margin: 0 0 var(--spacing-xs) 0;
  }
  
  .tip-content {
    font-size: 0.75rem;
    opacity: 0.8;
    margin: 0;
  }
  
  /* FAQ */
  .faq-section {
    margin-bottom: var(--spacing-xl);
  }
  
  .faq-list {
    background: var(--color-white);
    border: 3px solid var(--color-border);
  }
  
  .faq-item {
    border-bottom: 2px solid var(--color-border);
  }
  
  .faq-item:last-child {
    border-bottom: none;
  }
  
  .faq-question {
    font-family: var(--font-pixel);
    font-size: 0.75rem;
    padding: var(--spacing-md);
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: background 0.2s;
  }
  
  .faq-question:hover {
    background: var(--color-background);
  }
  
  .faq-question::after {
    content: '▼';
    font-size: 0.625rem;
    transition: transform 0.2s;
  }
  
  details[open] .faq-question::after {
    transform: rotate(180deg);
  }
  
  .faq-answer {
    padding: 0 var(--spacing-md) var(--spacing-md);
  }
  
  .faq-answer p {
    margin: 0;
    font-size: 0.875rem;
    opacity: 0.8;
    line-height: 1.6;
  }
  
  /* 帮助区域 */
  .help-section {
    text-align: center;
  }
  
  .help-card {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    padding: var(--spacing-xl);
    background: var(--color-white);
    border: 3px solid var(--color-border);
    box-shadow: 4px 4px 0 var(--color-border);
  }
  
  .help-icon {
    font-size: 3rem;
    margin-bottom: var(--spacing-sm);
  }
  
  .help-card h2 {
    font-family: var(--font-pixel);
    font-size: 1rem;
    margin: 0 0 var(--spacing-sm) 0;
  }
  
  .help-card p {
    margin: 0 0 var(--spacing-md) 0;
    opacity: 0.8;
  }
</style>

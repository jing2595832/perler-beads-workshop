---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="教程中心">
  <Header activeNav="tutorials" />
  
  <main class="tutorials-page">
    <div class="container">
      <div class="coming-soon-container">
        <!-- 顶部装饰 -->
        <div class="header-decoration">
          <div class="decoration-line">
            <span class="deco-pixel" style="--color: #FF6B6B;"></span>
            <span class="deco-pixel" style="--color: #4ECDC4;"></span>
            <span class="deco-pixel" style="--color: #FFE66D;"></span>
            <span class="deco-pixel" style="--color: #FF6B6B;"></span>
            <span class="deco-pixel" style="--color: #4ECDC4;"></span>
            <span class="deco-pixel" style="--color: #FFE66D;"></span>
            <span class="deco-pixel" style="--color: #FF6B6B;"></span>
          </div>
        </div>
        
        <!-- 主内容卡片 -->
        <div class="main-card pixel-card">
          <div class="card-header">
            <span class="header-icon">📚</span>
            <h1 class="page-title">教程中心即将上线</h1>
          </div>
          
          <div class="card-body">
            <p class="description">
              我们正在精心准备一系列拼豆制作教程<br/>
              从入门基础到进阶技巧，帮助您成为拼豆达人
            </p>
            
            <!-- 教程预览网格 -->
            <div class="preview-grid">
              <div class="preview-item">
                <div class="preview-icon">🎯</div>
                <h3 class="preview-title">入门指南</h3>
                <p class="preview-desc">拼豆基础工具与材料介绍</p>
              </div>
              
              <div class="preview-item">
                <div class="preview-icon">🔥</div>
                <h3 class="preview-title">熨烫技巧</h3>
                <p class="preview-desc">掌握完美的熨烫方法</p>
              </div>
              
              <div class="preview-item">
                <div class="preview-icon">🎨</div>
                <h3 class="preview-title">配色方案</h3>
                <p class="preview-desc">学习专业的颜色搭配</p>
              </div>
              
              <div class="preview-item">
                <div class="preview-icon">✨</div>
                <h3 class="preview-title">进阶技法</h3>
                <p class="preview-desc">立体造型与组合技巧</p>
              </div>
            </div>
            
            <!-- 通知订阅 -->
            <div class="subscribe-section">
              <div class="subscribe-box">
                <span class="bell-icon">🔔</span>
                <p class="subscribe-text">上线后第一时间通知您</p>
                <button class="pixel-btn subscribe-btn" onclick="notifyMe()">
                  提醒我
                </button>
              </div>
            </div>
          </div>
        </div>
        
        <!-- 底部装饰 -->
        <div class="footer-decoration">
          <div class="book-stack">
            <div class="book book-1"></div>
            <div class="book book-2"></div>
            <div class="book book-3"></div>
          </div>
        </div>
        
        <!-- 返回导航 -->
        <div class="nav-section">
          <a href="/patterns" class="nav-link">
            <span class="link-icon">🎨</span>
            浏览图纸库
          </a>
          <a href="/" class="nav-link secondary">
            <span class="link-icon">🏠</span>
            返回首页
          </a>
        </div>
      </div>
    </div>
  </main>
  
  <Footer />
</Layout>

<script>
  function notifyMe() {
    alert('感谢您的关注！教程中心上线后我们会通知您。');
  }
</script>

<style>
  .tutorials-page {
    padding: var(--spacing-2xl) 0;
    min-height: calc(100vh - 70px - 300px);
    display: flex;
    align-items: center;
  }
  
  .coming-soon-container {
    max-width: 700px;
    margin: 0 auto;
  }
  
  /* 顶部装饰 */
  .header-decoration {
    display: flex;
    justify-content: center;
    margin-bottom: var(--spacing-lg);
  }
  
  .decoration-line {
    display: flex;
    gap: 8px;
  }
  
  .deco-pixel {
    width: 20px;
    height: 20px;
    background-color: var(--color);
    border: 3px solid var(--color-border);
    animation: bouncePixel 1s ease-in-out infinite alternate;
  }
  
  .deco-pixel:nth-child(1) { animation-delay: 0s; }
  .deco-pixel:nth-child(2) { animation-delay: 0.1s; }
  .deco-pixel:nth-child(3) { animation-delay: 0.2s; }
  .deco-pixel:nth-child(4) { animation-delay: 0.3s; }
  .deco-pixel:nth-child(5) { animation-delay: 0.4s; }
  .deco-pixel:nth-child(6) { animation-delay: 0.5s; }
  .deco-pixel:nth-child(7) { animation-delay: 0.6s; }
  
  @keyframes bouncePixel {
    0% {
      transform: translateY(0);
    }
    100% {
      transform: translateY(-8px);
    }
  }
  
  /* 主卡片 */
  .main-card {
    text-align: center;
    margin-bottom: var(--spacing-xl);
  }
  
  .card-header {
    border-bottom: 3px dashed var(--color-border);
    padding-bottom: var(--spacing-lg);
    margin-bottom: var(--spacing-xl);
  }
  
  .header-icon {
    font-size: 3rem;
    display: block;
    margin-bottom: var(--spacing-md);
  }
  
  .page-title {
    font-size: 1.5rem;
    color: var(--color-primary);
    margin: 0;
  }
  
  .description {
    font-size: 1rem;
    color: var(--color-text);
    opacity: 0.8;
    line-height: 1.8;
    margin-bottom: var(--spacing-xl);
  }
  
  /* 预览网格 */
  .preview-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-xl);
  }
  
  @media (min-width: 600px) {
    .preview-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  
  .preview-item {
    background-color: var(--color-background);
    border: 3px solid var(--color-border);
    padding: var(--spacing-lg);
    transition: all 0.2s ease;
  }
  
  .preview-item:hover {
    transform: translateY(-4px);
    box-shadow: 4px 4px 0 var(--color-shadow);
  }
  
  .preview-icon {
    font-size: 2rem;
    margin-bottom: var(--spacing-sm);
  }
  
  .preview-title {
    font-family: var(--font-pixel);
    font-size: 0.625rem;
    color: var(--color-text);
    margin-bottom: var(--spacing-xs);
  }
  
  .preview-desc {
    font-size: 0.75rem;
    color: var(--color-text);
    opacity: 0.7;
    margin: 0;
  }
  
  /* 订阅区域 */
  .subscribe-section {
    margin-top: var(--spacing-xl);
  }
  
  .subscribe-box {
    background-color: var(--color-accent);
    border: 3px solid var(--color-border);
    padding: var(--spacing-lg);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-md);
  }
  
  .bell-icon {
    font-size: 2rem;
    animation: bellRing 2s ease-in-out infinite;
  }
  
  @keyframes bellRing {
    0%, 100% {
      transform: rotate(0deg);
    }
    10%, 30%, 50% {
      transform: rotate(10deg);
    }
    20%, 40% {
      transform: rotate(-10deg);
    }
  }
  
  .subscribe-text {
    font-size: 0.875rem;
    color: var(--color-text);
    margin: 0;
  }
  
  .subscribe-btn {
    font-size: 0.75rem;
  }
  
  /* 底部装饰 - 书本堆叠 */
  .footer-decoration {
    display: flex;
    justify-content: center;
    margin-bottom: var(--spacing-xl);
  }
  
  .book-stack {
    display: flex;
    align-items: flex-end;
    gap: 4px;
  }
  
  .book {
    width: 40px;
    border: 3px solid var(--color-border);
    box-shadow: 3px 3px 0 var(--color-shadow);
  }
  
  .book-1 {
    height: 50px;
    background-color: var(--color-primary);
  }
  
  .book-2 {
    height: 60px;
    background-color: var(--color-secondary);
  }
  
  .book-3 {
    height: 45px;
    background-color: var(--color-accent);
  }
  
  /* 导航区域 */
  .nav-section {
    display: flex;
    justify-content: center;
    gap: var(--spacing-md);
    flex-wrap: wrap;
  }
  
  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-md) var(--spacing-lg);
    background-color: var(--color-primary);
    color: var(--color-white);
    font-family: var(--font-pixel);
    font-size: 0.75rem;
    text-decoration: none;
    border: 3px solid var(--color-border);
    box-shadow: 4px 4px 0 var(--color-border);
    transition: all 0.1s ease;
  }
  
  .nav-link:hover {
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0 var(--color-border);
  }
  
  .nav-link.secondary {
    background-color: var(--color-secondary);
  }
  
  .link-icon {
    font-size: 1rem;
  }
  
  /* 响应式调整 */
  @media (max-width: 480px) {
    .main-card {
      margin: 0 var(--spacing-md) var(--spacing-xl);
    }
    
    .preview-grid {
      grid-template-columns: 1fr 1fr;
    }
    
    .nav-section {
      flex-direction: column;
      padding: 0 var(--spacing-md);
    }
    
    .nav-link {
      justify-content: center;
    }
  }
</style>

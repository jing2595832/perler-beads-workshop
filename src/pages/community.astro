---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="拼豆社区" description="加入拼豆社区，分享你的作品，发现更多创意灵感">
  <Header activeNav="community" />

  <main>
    <!-- 页面标题 -->
    <section class="page-header">
      <div class="container">
        <h1 class="page-title">
          <span class="title-icon">🌟</span>
          拼豆社区
        </h1>
        <p class="page-desc">分享创意，发现灵感，和拼豆爱好者一起交流</p>
      </div>
    </section>

    <!-- 统计卡片 -->
    <section class="stats-section">
      <div class="container">
        <div class="stats-grid">
          <div class="stat-card">
            <span class="stat-icon">🎨</span>
            <span class="stat-number">1,234</span>
            <span class="stat-label">分享作品</span>
          </div>
          <div class="stat-card">
            <span class="stat-icon">👥</span>
            <span class="stat-number">567</span>
            <span class="stat-label">活跃用户</span>
          </div>
          <div class="stat-card">
            <span class="stat-icon">💬</span>
            <span class="stat-number">8,901</span>
            <span class="stat-label">讨论帖子</span>
          </div>
          <div class="stat-card">
            <span class="stat-icon">❤️</span>
            <span class="stat-number">12K+</span>
            <span class="stat-label">累计点赞</span>
          </div>
        </div>
      </div>
    </section>

    <!-- 主内容区 -->
    <section class="community-main">
      <div class="container">
        <div class="community-layout">
          <!-- 左侧主内容 -->
          <div class="community-content">
            <!-- 筛选标签 -->
            <div class="filter-tabs">
              <button class="filter-tab active" data-filter="latest">最新</button>
              <button class="filter-tab" data-filter="popular">热门</button>
              <button class="filter-tab" data-filter="featured">精华</button>
            </div>

            <!-- 用户作品展示区 -->
            <div class="works-section">
              <h2 class="section-title">
                <span class="title-icon">🎨</span>
                社区作品
              </h2>
              <div class="works-grid" id="user-works-grid">
                <!-- 由JS动态渲染 -->
              </div>
            </div>

            <!-- 示例作品 -->
            <div class="examples-section">
              <h2 class="section-title">
                <span class="title-icon">✨</span>
                精选作品
              </h2>
              <div class="examples-grid" id="examples-grid">
                <!-- 由JS渲染示例数据 -->
              </div>
            </div>
          </div>

          <!-- 右侧边栏 -->
          <aside class="community-sidebar">
            <!-- 分享我的作品 -->
            <div class="sidebar-card">
              <a href="/design" class="share-cta-btn">
                <span class="cta-icon">🎨</span>
                <span class="cta-text">分享我的作品</span>
              </a>
            </div>

            <!-- 热门话题 -->
            <div class="sidebar-card">
              <h3 class="sidebar-title">🔥 热门话题</h3>
              <ul class="topic-list">
                <li class="topic-item">
                  <a href="#" class="topic-link"># 新手入门教程</a>
                  <span class="topic-count">328 讨论</span>
                </li>
                <li class="topic-item">
                  <a href="#" class="topic-link"># 每日拼豆挑战</a>
                  <span class="topic-count">256 讨论</span>
                </li>
                <li class="topic-item">
                  <a href="#" class="topic-link"># 国风拼豆创作</a>
                  <span class="topic-count">189 讨论</span>
                </li>
                <li class="topic-item">
                  <a href="#" class="topic-link"># 拼豆配色技巧</a>
                  <span class="topic-count">145 讨论</span>
                </li>
              </ul>
            </div>

            <!-- 社区公告 -->
            <div class="sidebar-card">
              <h3 class="sidebar-title">📢 社区公告</h3>
              <ul class="notice-list">
                <li class="notice-item">
                  <span class="notice-date">06-01</span>
                  <span class="notice-text">六月拼豆挑战赛开始报名啦！</span>
                </li>
                <li class="notice-item">
                  <span class="notice-date">05-28</span>
                  <span class="notice-text">新增立体拼豆教程专区</span>
                </li>
                <li class="notice-item">
                  <span class="notice-date">05-20</span>
                  <span class="notice-text">社区规则更新，请查看详情</span>
                </li>
              </ul>
            </div>

            <!-- 社区规则 -->
            <div class="sidebar-card">
              <h3 class="sidebar-title">📋 社区规则</h3>
              <ol class="rules-list">
                <li>尊重原创，转载请注明出处</li>
                <li>友善交流，禁止人身攻击</li>
                <li>分享作品请标注难度等级</li>
                <li>禁止发布与拼豆无关的内容</li>
                <li>遵守当地法律法规</li>
              </ol>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <!-- 底部CTA -->
    <section class="cta-section">
      <div class="container">
        <div class="cta-content">
          <h2 class="cta-title">加入拼豆社区</h2>
          <p class="cta-desc">和全球拼豆爱好者一起，分享创意，交流技巧，发现无限可能</p>
          <a href="/design" class="pixel-btn cta-btn">开始创作</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  const COMMUNITY_KEY = 'perlerCommunityWorks';

  // ===== 示例作品数据 =====
  const exampleWorks = [
    {
      id: 'example-1',
      title: '彩虹独角兽',
      author: '小豆子',
      description: '用16种颜色拼出的梦幻独角兽，送给女儿的生日礼物。',
      width: 20,
      height: 25,
      colors: ['#FF6B6B', '#FF8E53', '#FFE66D', '#4ECDC4', '#45B7D1', '#5B8DEF', '#9B59B6', '#FF6B9D', '#FFFFFF'],
      likes: 342,
      createdAt: '2024-05-28T10:00:00Z',
      isExample: true,
    },
    {
      id: 'example-2',
      title: '樱花杯垫',
      author: '花间集',
      description: '春天主题的樱花杯垫，粉色系配色温柔可爱。',
      width: 18,
      height: 18,
      colors: ['#FF6B9D', '#FFB8D0', '#FFE4C4', '#FFFFFF', '#4ECDC4'],
      likes: 256,
      createdAt: '2024-05-25T14:30:00Z',
      isExample: true,
    },
    {
      id: 'example-3',
      title: '马里奥蘑菇',
      author: '像素玩家',
      description: '经典游戏角色，红白配色，简单又可爱。',
      width: 15,
      height: 15,
      colors: ['#FF6B6B', '#FFFFFF', '#2D3436', '#4ECDC4'],
      likes: 198,
      createdAt: '2024-05-22T09:15:00Z',
      isExample: true,
    },
    {
      id: 'example-4',
      title: '星空钥匙扣',
      author: '星夜工坊',
      description: '深蓝底色配金色星星，做成钥匙扣特别好看。',
      width: 12,
      height: 12,
      colors: ['#5B8DEF', '#2D3436', '#FFE66D', '#FFFFFF'],
      likes: 167,
      createdAt: '2024-05-20T16:45:00Z',
      isExample: true,
    },
    {
      id: 'example-5',
      title: '第一个作品小猫咪',
      author: '新手小白',
      description: '我的第一个拼豆作品！虽然不太完美但很开心。',
      width: 15,
      height: 15,
      colors: ['#FFE4C4', '#FF6B9D', '#2D3436', '#FFFFFF'],
      likes: 423,
      createdAt: '2024-05-18T11:00:00Z',
      isExample: true,
    },
    {
      id: 'example-6',
      title: '祥云纹书签',
      author: '国风匠人',
      description: '传统祥云纹样设计的拼豆书签，古风韵味十足。',
      width: 8,
      height: 25,
      colors: ['#C0392B', '#FFE66D', '#FF6B6B', '#FFFFFF'],
      likes: 289,
      createdAt: '2024-05-15T08:30:00Z',
      isExample: true,
    },
  ];

  // ===== 初始化 =====
  document.addEventListener('DOMContentLoaded', () => {
    loadUserWorks();
    renderExamples();
    bindFilterTabs();
  });

  // ===== 加载用户作品 =====
  function loadUserWorks() {
    const grid = document.getElementById('user-works-grid');
    if (!grid) return;

    try {
      const works = JSON.parse(localStorage.getItem(COMMUNITY_KEY) || '[]');
      if (works.length > 0) {
        renderUserWorks(works);
      } else {
        grid.innerHTML = `
          <div class="empty-state">
            <span class="empty-icon">🎨</span>
            <p class="empty-text">还没有社区作品</p>
            <p class="empty-hint">去设计工具创作你的第一个作品吧！</p>
            <a href="/design" class="pixel-btn accent" style="font-size:0.5rem; display:inline-block; margin-top:var(--spacing-md);">开始创作</a>
          </div>
        `;
      }
    } catch {
      grid.innerHTML = '<p class="empty-text">加载作品失败</p>';
    }
  }

  // ===== 渲染用户作品 =====
  function renderUserWorks(works: any[]) {
    const grid = document.getElementById('user-works-grid');
    if (!grid) return;

    grid.innerHTML = '';
    works.forEach((work) => {
      const card = createWorkCard(work);
      grid.appendChild(card);
    });
  }

  // ===== 渲染示例作品 =====
  function renderExamples() {
    const grid = document.getElementById('examples-grid');
    if (!grid) return;

    grid.innerHTML = '';
    exampleWorks.forEach((work) => {
      const card = createWorkCard(work);
      grid.appendChild(card);
    });
  }

  // ===== 创建作品卡片 =====
  function createWorkCard(work: any): HTMLElement {
    const card = document.createElement('div');
    card.className = 'work-card';

    // 生成缩略图
    const thumbnail = generateThumbnail(work);

    card.innerHTML = `
      <div class="work-thumbnail">${thumbnail}</div>
      <div class="work-info">
        <h3 class="work-name">${escapeHtml(work.title || '未命名')}</h3>
        <div class="work-meta-row">
          <span class="work-author">👤 ${escapeHtml(work.author || '匿名')}</span>
          <span class="work-likes">❤️ ${work.likes || 0}</span>
        </div>
        ${work.description ? `<p class="work-desc-preview">${escapeHtml(work.description).substring(0, 50)}${work.description.length > 50 ? '...' : ''}</p>` : ''}
        <div class="work-colors-preview">
          ${(work.colors || []).slice(0, 6).map((c: string) => `<span class="mini-swatch" style="background-color:${c};${c === '#FFFFFF' ? 'border:1px solid #2D3436;' : ''}"></span>`).join('')}
          ${(work.colors || []).length > 6 ? `<span class="more-colors">+${work.colors.length - 6}</span>` : ''}
        </div>
      </div>
    `;

    // 点击跳转
    card.addEventListener('click', () => {
      if (work.isExample) {
        // 示例作品显示提示
        alert('这是精选示例作品，快去创作你自己的吧！');
      } else if (work.id) {
        window.location.href = `/design/${work.id}`;
      }
    });

    card.style.cursor = 'pointer';
    return card;
  }

  // ===== 生成缩略图 =====
  function generateThumbnail(work: any): string {
    if (work.grid && work.width && work.height) {
      const cellSize = Math.max(4, Math.min(10, Math.floor(120 / Math.max(work.width, work.height))));
      const totalW = work.width * cellSize;
      const totalH = work.height * cellSize;

      const canvas = document.createElement('canvas');
      canvas.width = totalW;
      canvas.height = totalH;
      const ctx = canvas.getContext('2d')!;

      ctx.fillStyle = '#F7F7F7';
      ctx.fillRect(0, 0, totalW, totalH);

      for (let y = 0; y < work.height; y++) {
        for (let x = 0; x < work.width; x++) {
          const color = work.grid[y]?.[x];
          if (color) {
            ctx.fillStyle = color;
            ctx.fillRect(x * cellSize, y * cellSize, cellSize, cellSize);
          }
        }
      }

      return `<img src="${canvas.toDataURL('image/png')}" alt="${escapeHtml(work.title || '')}" style="width:100%;height:100%;object-fit:contain;image-rendering:pixelated;" />`;
    }

    // 无grid数据时生成占位图
    const canvas = document.createElement('canvas');
    canvas.width = 120;
    canvas.height = 120;
    const ctx = canvas.getContext('2d')!;

    const colors = work.colors || ['#FF6B6B', '#4ECDC4', '#FFE66D'];
    const gridSize = 8;
    const cellSize = 120 / gridSize;

    for (let y = 0; y < gridSize; y++) {
      for (let x = 0; x < gridSize; x++) {
        ctx.fillStyle = colors[(x + y) % colors.length];
        ctx.fillRect(x * cellSize, y * cellSize, cellSize, cellSize);
      }
    }

    return `<img src="${canvas.toDataURL('image/png')}" alt="${escapeHtml(work.title || '')}" style="width:100%;height:100%;object-fit:contain;image-rendering:pixelated;" />`;
  }

  // ===== 筛选标签 =====
  function bindFilterTabs() {
    const tabs = document.querySelectorAll('.filter-tab');
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        tabs.forEach((t) => t.classList.remove('active'));
        tab.classList.add('active');

        const filter = tab.dataset.filter;
        if (filter === 'latest') {
          loadUserWorks();
        } else if (filter === 'popular') {
          sortByLikes();
        } else if (filter === 'featured') {
          showFeatured();
        }
      });
    });
  }

  function sortByLikes() {
    try {
      const works = JSON.parse(localStorage.getItem(COMMUNITY_KEY) || '[]');
      works.sort((a: any, b: any) => (b.likes || 0) - (a.likes || 0));
      renderUserWorks(works);
    } catch {
      // ignore
    }
  }

  function showFeatured() {
    try {
      const works = JSON.parse(localStorage.getItem(COMMUNITY_KEY) || '[]');
      const featured = works.filter((w: any) => (w.likes || 0) >= 10);
      if (featured.length > 0) {
        renderUserWorks(featured);
      } else {
        const grid = document.getElementById('user-works-grid');
        if (grid) {
          grid.innerHTML = `
            <div class="empty-state">
              <span class="empty-icon">⭐</span>
              <p class="empty-text">暂无精华作品</p>
              <p class="empty-hint">获得10个以上点赞的作品将自动入选精华</p>
            </div>
          `;
        }
      }
    } catch {
      // ignore
    }
  }

  // ===== 工具函数 =====
  function escapeHtml(str: string): string {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }
</script>

<style>
  /* 页面标题 */
  .page-header {
    background: linear-gradient(135deg, var(--color-white) 0%, var(--color-background) 100%);
    padding: var(--spacing-2xl) 0 var(--spacing-xl);
    text-align: center;
    border-bottom: var(--border-width) solid var(--color-border);
  }

  .page-title {
    font-family: var(--font-pixel);
    font-size: clamp(1.5rem, 4vw, 2rem);
    margin-bottom: var(--spacing-md);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-sm);
  }

  .title-icon {
    font-size: 1.2em;
  }

  .page-desc {
    font-size: 1rem;
    color: var(--color-text);
    opacity: 0.8;
  }

  /* 统计卡片 */
  .stats-section {
    padding: var(--spacing-lg) 0;
    background-color: var(--color-white);
    border-bottom: var(--border-width) solid var(--color-border);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-md);
  }

  @media (min-width: 640px) {
    .stats-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .stat-card {
    background-color: var(--color-background);
    border: var(--border-width) solid var(--color-border);
    box-shadow: 3px 3px 0 var(--color-border);
    padding: var(--spacing-md);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-xs);
  }

  .stat-icon {
    font-size: 1.5rem;
  }

  .stat-number {
    font-family: var(--font-pixel);
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--color-primary);
  }

  .stat-label {
    font-family: var(--font-pixel);
    font-size: 0.5rem;
    color: var(--color-text);
    opacity: 0.7;
  }

  /* 主内容区 */
  .community-main {
    padding: var(--spacing-xl) 0 var(--spacing-2xl);
    background-color: var(--color-background);
  }

  .community-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-lg);
  }

  @media (min-width: 1024px) {
    .community-layout {
      grid-template-columns: 1fr 280px;
    }
  }

  /* 筛选标签 */
  .filter-tabs {
    display: flex;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-lg);
  }

  .filter-tab {
    padding: var(--spacing-xs) var(--spacing-md);
    font-family: var(--font-pixel);
    font-size: 0.5rem;
    border: 2px solid var(--color-border);
    background-color: var(--color-white);
    cursor: pointer;
    transition: all 0.1s;
  }

  .filter-tab:hover {
    background-color: var(--color-accent);
  }

  .filter-tab.active {
    background-color: var(--color-primary);
    color: var(--color-white);
    border-color: var(--color-border);
    box-shadow: 2px 2px 0 var(--color-border);
  }

  /* 作品网格 */
  .section-title {
    font-family: var(--font-pixel);
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--color-text);
    margin-bottom: var(--spacing-lg);
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
  }

  .works-section {
    margin-bottom: var(--spacing-2xl);
  }

  .works-grid,
  .examples-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-md);
  }

  @media (min-width: 640px) {
    .works-grid,
    .examples-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* 作品卡片 */
  .work-card {
    background-color: var(--color-white);
    border: var(--border-width) solid var(--color-border);
    box-shadow: 3px 3px 0 var(--color-border);
    overflow: hidden;
    transition: all 0.2s ease;
  }

  .work-card:hover {
    transform: translate(-2px, -2px);
    box-shadow: 5px 5px 0 var(--color-border);
  }

  .work-card:active {
    transform: translate(3px, 3px);
    box-shadow: 0 0 0 var(--color-border);
  }

  .work-thumbnail {
    aspect-ratio: 1;
    background-color: var(--color-background);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-bottom: 2px solid var(--color-border);
  }

  .work-info {
    padding: var(--spacing-sm);
  }

  .work-name {
    font-family: var(--font-pixel);
    font-size: 0.5rem;
    color: var(--color-text);
    margin-bottom: var(--spacing-xs);
    line-height: 1.4;
  }

  .work-meta-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-pixel);
    font-size: 0.375rem;
    color: var(--color-text);
    opacity: 0.7;
    margin-bottom: var(--spacing-xs);
  }

  .work-desc-preview {
    font-size: 0.75rem;
    color: var(--color-text);
    opacity: 0.6;
    margin: 0 0 var(--spacing-xs) 0;
    line-height: 1.4;
  }

  .work-colors-preview {
    display: flex;
    align-items: center;
    gap: 3px;
  }

  .mini-swatch {
    display: inline-block;
    width: 14px;
    height: 14px;
    border: 1px solid var(--color-border);
  }

  .more-colors {
    font-family: var(--font-pixel);
    font-size: 0.375rem;
    color: var(--color-text);
    opacity: 0.5;
  }

  /* 空状态 */
  .empty-state {
    grid-column: 1 / -1;
    text-align: center;
    padding: var(--spacing-2xl) 0;
  }

  .empty-icon {
    font-size: 3rem;
    display: block;
    margin-bottom: var(--spacing-md);
  }

  .empty-text {
    font-family: var(--font-pixel);
    font-size: 0.75rem;
    color: var(--color-text);
    margin-bottom: var(--spacing-xs);
  }

  .empty-hint {
    font-size: 0.875rem;
    color: var(--color-text);
    opacity: 0.6;
    margin: 0;
  }

  /* 侧边栏 */
  .community-sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  @media (min-width: 1024px) {
    .community-sidebar {
      position: sticky;
      top: 80px;
    }
  }

  .sidebar-card {
    background-color: var(--color-white);
    border: var(--border-width) solid var(--color-border);
    box-shadow: 3px 3px 0 var(--color-border);
    padding: var(--spacing-md);
  }

  .sidebar-title {
    font-family: var(--font-pixel);
    font-size: 0.625rem;
    color: var(--color-text);
    margin-bottom: var(--spacing-md);
    padding-bottom: var(--spacing-xs);
    border-bottom: 2px dashed var(--color-border);
  }

  /* 分享CTA */
  .share-cta-btn {
    display: flex;
    align-items: center;
    justify-content: center;

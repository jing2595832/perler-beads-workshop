---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PatternCard from '../../components/PatternCard.astro';
import { patterns } from '../../data/patterns';

export function getStaticPaths() {
  return patterns.map((pattern) => ({
    params: { id: pattern.id },
    props: { pattern },
  }));
}

const { pattern } = Astro.props;

// 难度星星
const stars = '⭐'.repeat(pattern.difficulty);

// 同分类的其他图纸（排除当前，最多6个）
const relatedPatterns = patterns
  .filter((p) => p.category === pattern.category && p.id !== pattern.id)
  .slice(0, 6);

// 分类名称映射
const categoryMap: Record<string, string> = {
  emoji: '表情符号',
  animal: '动物',
  food: '美食',
  text: '文字',
  geo: '几何',
  chinese: '国风',
  plant: '植物',
  holiday: '节日',
  daily: '日常',
  vehicle: '交通工具',
  advanced: '进阶',
};
---

<Layout title={`${pattern.name} - 图纸详情`} description={`${pattern.name}(${pattern.nameEn}) 拼豆图纸详情，难度${pattern.difficulty}星，尺寸${pattern.width}x${pattern.height}`}>
  <Header activeNav="patterns" />

  <main>
    <!-- 面包屑导航 -->
    <nav class="breadcrumb" aria-label="面包屑导航">
      <div class="container">
        <a href="/patterns">图纸库</a>
        <span class="breadcrumb-sep">/</span>
        <a href={`/patterns?category=${pattern.category}`}>{categoryMap[pattern.category] || pattern.category}</a>
        <span class="breadcrumb-sep">/</span>
        <span class="breadcrumb-current">{pattern.name}</span>
      </div>
    </nav>

    <!-- 图纸详情区 -->
    <section class="pattern-detail">
      <div class="container">
        <div class="detail-layout">
          <!-- 左侧：图纸大图 -->
          <div class="detail-image-section">
            <div class="image-wrapper">
              <img
                src={`/patterns/${pattern.filename}`}
                alt={pattern.name}
                class="pattern-detail-image"
                loading="lazy"
                decoding="async"
                onerror={`this.src='/images/placeholder.svg'; this.onerror=null;`}
              />
            </div>

            <!-- 下载按钮 -->
            <div class="download-actions">
              <a
                href={`/patterns/${pattern.filename}`}
                download={pattern.filename}
                class="pixel-btn download-btn"
              >
                <span class="btn-icon">📥</span>
                下载图纸 PNG
              </a>
            </div>
          </div>

          <!-- 右侧：图纸信息 -->
          <div class="detail-info-section">
            <h1 class="detail-title">{pattern.name}</h1>
            <p class="detail-title-en">{pattern.nameEn}</p>
            <p class="detail-title-ja">{pattern.nameJa}</p>

            <!-- 信息卡片 -->
            <div class="info-cards">
              <div class="info-card">
                <span class="info-label">分类</span>
                <span class="info-value">{categoryMap[pattern.category] || pattern.category}</span>
              </div>
              <div class="info-card">
                <span class="info-label">难度</span>
                <span class="info-value">{stars} ({pattern.difficulty}/5)</span>
              </div>
              <div class="info-card">
                <span class="info-label">尺寸</span>
                <span class="info-value">{pattern.width} x {pattern.height} 格</span>
              </div>
              <div class="info-card">
                <span class="info-label">颜色数</span>
                <span class="info-value">{pattern.colors.length} 种</span>
              </div>
            </div>

            <!-- 颜色数量 -->
            <div class="color-section">
              <h3 class="section-label">使用颜色</h3>
              <span class="color-count">{pattern.colors} 种颜色</span>
            </div>

            <!-- 返回按钮 -->
            <div class="back-actions">
              <a href="/patterns" class="pixel-btn secondary">
                <span class="btn-icon">←</span>
                返回图纸库
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 相关图纸推荐 -->
    {relatedPatterns.length > 0 && (
      <section class="related-section">
        <div class="container">
          <h2 class="section-title">
            <span class="title-icon">💡</span>
            同类图纸推荐
          </h2>
          <div class="related-grid">
            {relatedPatterns.map((p) => (
              <PatternCard pattern={p} />
            ))}
          </div>
        </div>
      </section>
    )}
  </main>

  <Footer />
</Layout>

<style>
  /* 面包屑导航 */
  .breadcrumb {
    padding: var(--spacing-md) 0;
    background-color: var(--color-white);
    border-bottom: 2px solid var(--color-border);
    font-family: var(--font-pixel);
    font-size: 0.5rem;
  }

  .breadcrumb .container {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    flex-wrap: wrap;
  }

  .breadcrumb a {
    color: var(--color-secondary);
    text-decoration: none;
    transition: color 0.2s;
  }

  .breadcrumb a:hover {
    color: var(--color-primary);
  }

  .breadcrumb-sep {
    color: var(--color-text);
    opacity: 0.4;
  }

  .breadcrumb-current {
    color: var(--color-text);
    opacity: 0.7;
  }

  /* 图纸详情区 */
  .pattern-detail {
    padding: var(--spacing-xl) 0;
    background-color: var(--color-background);
  }

  .detail-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-xl);
  }

  @media (min-width: 768px) {
    .detail-layout {
      grid-template-columns: 1fr 1fr;
      align-items: start;
    }
  }

  /* 图纸大图 */
  .image-wrapper {
    background-color: var(--color-white);
    border: var(--border-width) solid var(--color-border);
    box-shadow: var(--shadow-offset) var(--shadow-offset) 0 var(--color-shadow);
    padding: var(--spacing-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 1;
    overflow: hidden;
  }

  .pattern-detail-image {
    max-width: 100%;
    max-height: 100%;
    image-rendering: pixelated;
    object-fit: contain;
  }

  /* 下载按钮 */
  .download-actions {
    margin-top: var(--spacing-md);
    text-align: center;
  }

  .download-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-sm);
    text-decoration: none;
    font-size: 0.75rem;
    padding: var(--spacing-sm) var(--spacing-lg);
  }

  .btn-icon {
    font-size: 1em;
  }

  /* 图纸信息 */
  .detail-info-section {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .detail-title {
    font-family: var(--font-pixel);
    font-size: clamp(1.25rem, 3vw, 2rem);
    color: var(--color-text);
    margin-bottom: 0;
  }

  .detail-title-en {
    font-family: var(--font-body-en);
    font-size: 1rem;
    color: var(--color-text);
    opacity: 0.6;
    margin-bottom: 0;
  }

  .detail-title-ja {
    font-family: var(--font-body-ja);
    font-size: 0.875rem;
    color: var(--color-text);
    opacity: 0.5;
    margin-bottom: 0;
  }

  /* 信息卡片 */
  .info-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-sm);
    margin-top: var(--spacing-md);
  }

  .info-card {
    background-color: var(--color-white);
    border: var(--border-width) solid var(--color-border);
    box-shadow: 3px 3px 0 var(--color-border);
    padding: var(--spacing-sm) var(--spacing-md);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }

  .info-label {
    font-family: var(--font-pixel);
    font-size: 0.5rem;
    color: var(--color-text);
    opacity: 0.6;
    text-transform: uppercase;
  }

  .info-value {
    font-family: var(--font-pixel);
    font-size: 0.625rem;
    color: var(--color-text);
  }

  /* 颜色列表 */
  .color-section {
    margin-top: var(--spacing-md);
  }

  .section-label {
    font-family: var(--font-pixel);
    font-size: 0.625rem;
    color: var(--color-text);
    margin-bottom: var(--spacing-sm);
  }

  .color-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-xs);
  }

  .color-tag {
    display: inline-block;
    padding: var(--spacing-xs) var(--spacing-sm);
    font-family: var(--font-pixel);
    font-size: 0.5rem;
    background-color: var(--color-accent);
    color: var(--color-text);
    border: 2px solid var(--color-border);
  }

  /* 返回按钮 */
  .back-actions {
    margin-top: var(--spacing-lg);
  }

  .back-actions .pixel-btn {
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-sm);
  }

  /* 相关图纸推荐 */
  .related-section {
    padding: var(--spacing-xl) 0 var(--spacing-2xl);
    background-color: var(--color-white);
    border-top: var(--border-width) solid var(--color-border);
  }

  .section-title {
    font-family: var(--font-pixel);
    font-size: clamp(1rem, 2vw, 1.5rem);
    color: var(--color-text);
    margin-bottom: var(--spacing-lg);
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
  }

  .title-icon {
    font-size: 1.2em;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-md);
  }

  @media (min-width: 640px) {
    .related-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .related-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: var(--spacing-lg);
    }
  }
</style>

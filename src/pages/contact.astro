---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
  title="联系我们" 
  description="联系拼豆豆工坊 - 商务合作、内容投稿、问题反馈"
>
  <Header />
  
  <main class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="font-pixel text-2xl mb-8 text-center">联系我们</h1>
    
    <div class="pixel-card p-8 space-y-8">
      <!-- 邮箱联系 -->
      <section class="text-center">
        <div class="text-4xl mb-4">📧</div>
        <h2 class="font-pixel text-sm mb-4">电子邮箱</h2>
        <a href="mailto:jing2595832@163.com" class="text-primary hover:underline text-lg">
          jing2595832@163.com
        </a>
        <p class="text-gray-600 mt-2">商务合作、内容投稿、问题反馈</p>
      </section>
      
      <!-- 分隔线 -->
      <div class="border-t-2 border-border"></div>
      
      <!-- 其他渠道 -->
      <section>
        <h2 class="font-pixel text-sm mb-6 text-center">其他联系方式</h2>
        
        <div class="grid md:grid-cols-2 gap-6">
          <!-- 微信公众号 -->
          <div class="contact-item coming-soon p-6 border-2 border-dashed border-border text-center">
            <div class="text-3xl mb-2">💬</div>
            <h3 class="font-medium mb-1">微信公众号</h3>
            <p class="text-gray-500">建设中...</p>
          </div>
          
          <!-- 社交媒体 -->
          <div class="contact-item coming-soon p-6 border-2 border-dashed border-border text-center">
            <div class="text-3xl mb-2">📱</div>
            <h3 class="font-medium mb-1">社交媒体</h3>
            <p class="text-gray-500">建设中...</p>
          </div>
        </div>
      </section>
      
      <!-- 反馈提示 -->
      <div class="bg-accent/20 p-6 border-2 border-border">
        <div class="flex items-start gap-4">
          <span class="text-2xl">💡</span>
          <div>
            <h3 class="font-pixel text-xs mb-2">有建议或反馈？</h3>
            <p class="text-gray-700 text-sm">
              我们非常重视您的意见！无论是网站功能建议、图纸需求，还是发现了bug，
              都欢迎通过邮件与我们联系。我们会认真阅读每一封邮件。
            </p>
          </div>
        </div>
      </div>
    </div>
    
    <div class="text-center mt-8">
      <a href="/about" class="pixel-btn secondary">
        ← 返回关于我们
      </a>
    </div>
  </main>
  
  <Footer />
</Layout>

<style>
  .pixel-card {
    background: white;
    border: 4px solid var(--color-border);
    box-shadow: 6px 6px 0 var(--color-shadow);
  }
  
  .contact-item {
    transition: all 0.2s;
  }
  
  .contact-item.coming-soon {
    opacity: 0.7;
  }
  
  .contact-item.coming-soon:hover {
    opacity: 1;
    background-color: var(--color-accent);
  }
</style>

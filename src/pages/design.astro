---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="设计工具" description="在线拼豆设计工具，自由创作像素艺术作品">
  <Header activeNav="design" />

  <main>
    <!-- 页面标题 -->
    <section class="page-header">
      <div class="container">
        <h1 class="page-title">
          <span class="title-icon">🎨</span>
          设计工具
        </h1>
        <p class="page-desc">在线创作专属拼豆作品，支持导出PNG、打印和分享</p>
      </div>
    </section>

    <!-- 设计工具主体 -->
    <section class="design-section">
      <div class="container">
        <div class="design-layout">
          <!-- 左侧工具栏 -->
          <aside class="toolbar">
            <!-- 画布设置 -->
            <div class="tool-group">
              <h3 class="tool-group-title">画布设置</h3>
              <div class="canvas-settings">
                <label class="setting-label">
                  宽
                  <input type="number" id="canvas-width" min="5" max="50" value="20" class="setting-input" />
                </label>
                <span class="setting-x">x</span>
                <label class="setting-label">
                  高
                  <input type="number" id="canvas-height" min="5" max="50" value="20" class="setting-input" />
                </label>
                <button id="apply-size-btn" class="pixel-btn accent" style="font-size:0.5rem; padding: var(--spacing-xs) var(--spacing-sm);">
                  应用
                </button>
              </div>
            </div>

            <!-- 工具 -->
            <div class="tool-group">
              <h3 class="tool-group-title">工具</h3>
              <div class="tool-buttons">
                <button class="tool-btn active" data-tool="brush" title="画笔 (B)">
                  <span class="tool-icon">✏️</span>
                  <span class="tool-name">画笔</span>
                </button>
                <button class="tool-btn" data-tool="eraser" title="橡皮擦 (E)">
                  <span class="tool-icon">🧼</span>
                  <span class="tool-name">橡皮擦</span>
                </button>
                <button class="tool-btn" data-tool="fill" title="填充 (F)">
                  <span class="tool-icon">🪣</span>
                  <span class="tool-name">填充</span>
                </button>
                <button class="tool-btn" data-tool="picker" title="取色器 (I)">
                  <span class="tool-icon">💧</span>
                  <span class="tool-name">取色器</span>
                </button>
              </div>
            </div>

            <!-- 操作 -->
            <div class="tool-group">
              <h3 class="tool-group-title">操作</h3>
              <div class="action-buttons">
                <button id="undo-btn" class="action-btn" title="撤销 (Ctrl+Z)">↩ 撤销</button>
                <button id="redo-btn" class="action-btn" title="重做 (Ctrl+Y)">↪ 重做</button>
                <button id="clear-btn" class="action-btn danger" title="清空画布">🗑 清空</button>
              </div>
            </div>

            <!-- 导出 -->
            <div class="tool-group">
              <h3 class="tool-group-title">导出</h3>
              <div class="export-buttons">
                <button id="export-png-btn" class="pixel-btn secondary" style="font-size:0.5rem; width:100%;">
                  📥 下载 PNG
                </button>
                <button id="export-pdf-btn" class="pixel-btn secondary" style="font-size:0.5rem; width:100%;">
                  🖨 打印 PDF
                </button>
                <button id="export-json-btn" class="pixel-btn secondary" style="font-size:0.5rem; width:100%;">
                  📋 导出 JSON
                </button>
                <button id="share-btn" class="pixel-btn" style="font-size:0.5rem; width:100%;">
                  🌐 分享作品
                </button>
              </div>
            </div>

            <!-- 使用提示 -->
            <div class="tool-group">
              <h3 class="tool-group-title">使用提示</h3>
              <div class="tips-area">
                <p>左键绘制，右键擦除</p>
                <p>拖拽可连续绘制</p>
                <p>Ctrl+Z 撤销 / Ctrl+Y 重做</p>
                <p>作品自动保存到本地</p>
              </div>
            </div>
          </aside>

          <!-- 中间画布区 -->
          <div class="canvas-area">
            <div class="canvas-wrapper" id="canvas-wrapper">
              <div class="pixel-canvas" id="pixel-canvas"></div>
            </div>
          </div>

          <!-- 右侧颜色面板 -->
          <aside class="color-panel">
            <!-- 拼豆颜色 -->
            <div class="tool-group">
              <h3 class="tool-group-title">拼豆颜色</h3>
              <div class="color-grid" id="color-grid"></div>
            </div>

            <!-- 最近使用颜色 -->
            <div class="tool-group">
              <h3 class="tool-group-title">最近使用</h3>
              <div class="recent-colors" id="recent-colors"></div>
            </div>

            <!-- 当前颜色预览 -->
            <div class="tool-group">
              <h3 class="tool-group-title">当前颜色</h3>
              <div class="current-color-preview" id="current-color-preview">
                <div class="preview-swatch" id="preview-swatch" style="background-color: #FF6B6B;"></div>
                <span class="preview-hex" id="preview-hex">#FF6B6B</span>
              </div>
            </div>
          </aside>
        </div>
      </div>
    </section>
  </main>

  <!-- 分享模态框 -->
  <div class="modal-overlay" id="share-modal" style="display:none;">
    <div class="modal-content">
      <div class="modal-header">
        <h2 class="modal-title">分享作品</h2>
        <button class="modal-close" id="modal-close-btn">&times;</button>
      </div>
      <div class="modal-body">
        <label class="modal-label">
          作品标题
          <input type="text" id="share-title" class="modal-input" placeholder="给作品起个名字..." />
        </label>
        <label class="modal-label">
          作者
          <input type="text" id="share-author" class="modal-input" placeholder="你的昵称..." />
        </label>
        <label class="modal-label">
          描述
          <textarea id="share-desc" class="modal-textarea" placeholder="介绍一下你的作品..."></textarea>
        </label>
      </div>
      <div class="modal-footer">
        <button id="copy-link-btn" class="pixel-btn secondary" style="font-size:0.5rem;">📋 复制分享链接</button>
        <button id="publish-btn" class="pixel-btn" style="font-size:0.5rem;">🚀 发布到社区</button>
      </div>
    </div>
  </div>

  <Footer />
</Layout>

<script>
  // ===== 拼豆颜色面板 =====
  const BEAD_COLORS: { name: string; hex: string }[] = [
    { name: '红', hex: '#FF6B6B' },
    { name: '橙', hex: '#FF8E53' },
    { name: '黄', hex: '#FFE66D' },
    { name: '绿', hex: '#4ECDC4' },
    { name: '青', hex: '#45B7D1' },
    { name: '蓝', hex: '#5B8DEF' },
    { name: '紫', hex: '#9B59B6' },
    { name: '粉', hex: '#FF6B9D' },
    { name: '棕', hex: '#8B4513' },
    { name: '黑', hex: '#2D3436' },
    { name: '白', hex: '#FFFFFF' },
    { name: '灰', hex: '#636E72' },
    { name: '浅粉', hex: '#FFB8D0' },
    { name: '浅蓝', hex: '#A8E6CF' },
    { name: '米色', hex: '#FFE4C4' },
    { name: '深红', hex: '#C0392B' },
  ];

  // ===== 状态管理 =====
  let canvasWidth = 20;
  let canvasHeight = 20;
  let currentColor = '#FF6B6B';
  let currentTool: 'brush' | 'eraser' | 'fill' | 'picker' = 'brush';
  let grid: (string | null)[][] = [];
  let isDrawing = false;
  let undoStack: (string | null)[][][] = [];
  let redoStack: (string | null)[][][] = [];
  let recentColors: string[] = [];

  const STORAGE_KEY = 'perlerDesigner';
  const COMMUNITY_KEY = 'perlerCommunityWorks';

  // ===== 初始化 =====
  function init() {
    loadFromStorage();
    renderColorGrid();
    renderRecentColors();
    renderCanvas();
    bindEvents();
    updateCurrentColorPreview();
  }

  // ===== 本地存储 =====
  function loadFromStorage() {
    try {
      const saved = localStorage.getItem(STORAGE_KEY);
      if (saved) {
        const data = JSON.parse(saved);
        canvasWidth = data.width || 20;
        canvasHeight = data.height || 20;
        grid = data.grid || createEmptyGrid(canvasWidth, canvasHeight);
        recentColors = data.recentColors || [];
        if (data.currentColor) currentColor = data.currentColor;
        document.getElementById('canvas-width')!.setAttribute('value', String(canvasWidth));
        document.getElementById('canvas-height')!.setAttribute('value', String(canvasHeight));
      } else {
        grid = createEmptyGrid(canvasWidth, canvasHeight);
      }
    } catch {
      grid = createEmptyGrid(canvasWidth, canvasHeight);
    }
  }

  function saveToStorage() {
    try {
      const data = {
        width: canvasWidth,
        height: canvasHeight,
        grid: grid,
        currentColor: currentColor,
        recentColors: recentColors.slice(0, 8),
      };
      localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
    } catch {
      // storage full or unavailable
    }
  }

  function createEmptyGrid(w: number, h: number): (string | null)[][] {
    return Array.from({ length: h }, () => Array.from({ length: w }, () => null));
  }

  // ===== 颜色面板 =====
  function renderColorGrid() {
    const container = document.getElementById('color-grid')!;
    container.innerHTML = '';
    BEAD_COLORS.forEach((c) => {
      const btn = document.createElement('button');
      btn.className = 'color-swatch';
      btn.style.backgroundColor = c.hex;
      btn.title = `${c.name} (${c.hex})`;
      btn.dataset.color = c.hex;
      if (c.hex === '#FFFFFF') {
        btn.style.border = '2px solid #2D3436';
      }
      if (c.hex === currentColor) {
        btn.classList.add('active');
      }
      btn.addEventListener('click', () => selectColor(c.hex));
      container.appendChild(btn);
    });
  }

  function renderRecentColors() {
    const container = document.getElementById('recent-colors')!;
    container.innerHTML = '';
    if (recentColors.length === 0) {
      const empty = document.createElement('span');
      empty.className = 'empty-hint';
      empty.textContent = '暂无';
      container.appendChild(empty);
      return;
    }
    recentColors.forEach((hex) => {
      const btn = document.createElement('button');
      btn.className = 'color-swatch small';
      btn.style.backgroundColor = hex;
      btn.title = hex;
      btn.dataset.color = hex;
      if (hex === '#FFFFFF') {
        btn.style.border = '2px solid #2D3436';
      }
      btn.addEventListener('click', () => selectColor(hex));
      container.appendChild(btn);
    });
  }

  function selectColor(hex: string) {
    currentColor = hex;
    addRecentColor(hex);
    updateCurrentColorPreview();
    renderColorGrid();
    renderRecentColors();
    saveToStorage();
    // 如果当前是橡皮擦或取色器，自动切换回画笔
    if (currentTool === 'eraser' || currentTool === 'picker') {
      setTool('brush');
    }
  }

  function addRecentColor(hex: string) {
    recentColors = recentColors.filter((c) => c !== hex);
    recentColors.unshift(hex);
    recentColors = recentColors.slice(0, 8);
  }

  function updateCurrentColorPreview() {
    const swatch = document.getElementById('preview-swatch') as HTMLElement;
    const hexLabel = document.getElementById('preview-hex') as HTMLElement;
    if (swatch) {
      swatch.style.backgroundColor = currentColor;
      if (currentColor === '#FFFFFF') {
        swatch.style.border = '2px solid #2D3436';
      } else {
        swatch.style.border = 'none';
      }
    }
    if (hexLabel) hexLabel.textContent = currentColor;
  }

  // ===== 画布渲染 =====
  function renderCanvas() {
    const container = document.getElementById('pixel-canvas')!;
    container.innerHTML = '';

    // 计算格子大小
    const maxCanvasSize = Math.min(600, window.innerWidth - 80);
    const cellSize = Math.max(12, Math.min(30, Math.floor(maxCanvasSize / Math.max(canvasWidth, canvasHeight))));

    container.style.display = 'grid';
    container.style.gridTemplateColumns = `repeat(${canvasWidth}, ${cellSize}px)`;
    container.style.gridTemplateRows = `repeat(${canvasHeight}, ${cellSize}px)`;
    container.style.gap = '1px';
    container.style.backgroundColor = '#2D3436';
    container.style.border = '3px solid #2D3436';
    container.style.boxShadow = '4px 4px 0 rgba(44,62,80,0.2)';

    for (let y = 0; y < canvasHeight; y++) {
      for (let x = 0; x < canvasWidth; x++) {
        const cell = document.createElement('div');
        cell.className = 'pixel-cell';
        cell.dataset.x = String(x);
        cell.dataset.y = String(y);
        cell.style.width = cellSize + 'px';
        cell.style.height = cellSize + 'px';
        cell.style.backgroundColor = grid[y][x] || '#F7F7F7';
        cell.style.cursor = currentTool === 'picker' ? 'crosshair' : 'pointer';
        cell.style.imageRendering = 'pixelated';

        // 鼠标事件
        cell.addEventListener('mousedown', (e) => {
          e.preventDefault();
          isDrawing = true;
          handleCellAction(x, y);
        });
        cell.addEventListener('mouseenter', () => {
          if (isDrawing && (currentTool === 'brush' || currentTool === 'eraser')) {
            handleCellAction(x, y);
          }
        });
        cell.addEventListener('contextmenu', (e) => {
          e.preventDefault();
          eraseCell(x, y);
        });

        container.appendChild(cell);
      }
    }
  }

  // ===== 工具操作 =====
  function handleCellAction(x: number, y: number) {
    switch (currentTool) {
      case 'brush':
        paintCell(x, y);
        break;
      case 'eraser':
        eraseCell(x, y);
        break;
      case 'fill':
        floodFill(x, y, currentColor);
        break;
      case 'picker':
        pickColor(x, y);
        break;
    }
  }

  function paintCell(x: number, y: number) {
    if (grid[y][x] === currentColor) return;
    pushUndo();
    grid[y][x] = currentColor;
    updateCell(x, y);
    saveToStorage();
  }

  function eraseCell(x: number, y: number) {
    if (grid[y][x] === null) return;
    pushUndo();
    grid[y][x] = null;
    updateCell(x, y);
    saveToStorage();
  }

  function pickColor(x: number, y: number) {
    const color = grid[y][x];
    if (color) {
      selectColor(color);
    }
  }

  function floodFill(startX: number, startY: number, fillColor: string) {
    const targetColor = grid[startY][startX];
    if (targetColor === fillColor) return;
    pushUndo();

    const stack: [number, number][] = [[startX, startY]];
    const visited = new Set<string>();

    while (stack.length > 0) {
      const [x, y] = stack.pop()!;
      const key = `${x},${y}`;
      if (visited.has(key)) continue;
      if (x < 0 || x >= canvasWidth || y < 0 || y >= canvasHeight) continue;
      if (grid[y][x] !== targetColor) continue;

      visited.add(key);
      grid[y][x] = fillColor;
      updateCell(x, y);

      stack.push([x + 1, y], [x - 1, y], [x, y + 1], [x, y - 1]);
    }
    saveToStorage();
  }

  function updateCell(x: number, y: number) {
    const cell = document.querySelector(`.pixel-cell[data-x="${x}"][data-y="${y}"]`) as HTMLElement;
    if (cell) {
      cell.style.backgroundColor = grid[y][x] || '#F7F7F7';
    }
  }

  // ===== 撤销/重做 =====
  function pushUndo() {
    undoStack.push(grid.map((row) => [...row]));
    if (undoStack.length > 50) undoStack.shift();
    redoStack = [];
  }

  function undo() {
    if (undoStack.length === 0) return;
    redoStack.push(grid.map((row) => [...row]));
    grid = undoStack.pop()!;
    renderCanvas();
    saveToStorage();
  }

  function redo() {
    if (redoStack.length === 0) return;
    undoStack.push(grid.map((row) => [...row]));
    grid = redoStack.pop()!;
    renderCanvas();
    saveToStorage();
  }

  // ===== 导出功能 =====
  function exportPNG() {
    const cellSize = 20;
    const padding = 1;
    const totalW = canvasWidth * (cellSize + padding) + padding;
    const totalH = canvasHeight * (cellSize + padding) + padding;

    const canvas = document.createElement('canvas');
    canvas.width = totalW;
    canvas.height = totalH;
    const ctx = canvas.getContext('2d')!;

    // 背景
    ctx.fillStyle = '#2D3436';
    ctx.fillRect(0, 0, totalW, totalH);

    for (let y = 0; y < canvasHeight; y++) {
      for (let x = 0; x < canvasWidth; x++) {
        const px = padding + x * (cellSize + padding);
        const py = padding + y * (cellSize + padding);
        ctx.fillStyle = grid[y][x] || '#F7F7F7';
        ctx.fillRect(px, py, cellSize, cellSize);
      }
    }

    const link = document.createElement('a');
    link.download = `perler-design-${Date.now()}.png`;
    link.href = canvas.toDataURL('image/png');
    link.click();
  }

  function exportJSON() {
    const data = {
      width: canvasWidth,
      height: canvasHeight,
      grid: grid,
      createdAt: new Date().toISOString(),
    };
    const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
    const link = document.createElement('a');
    link.download = `perler-design-${Date.now()}.json`;
    link.href = URL.createObjectURL(blob);
    link.click();
    URL.revokeObjectURL(link.href);
  }

  function printPDF() {
    const cellSize = 20;
    const padding = 1;
    const totalW = canvasWidth * (cellSize + padding) + padding;
    const totalH = canvasHeight * (cellSize + padding) + padding;

    const canvas = document.createElement('canvas');
    canvas.width = totalW;
    canvas.height = totalH;
    const ctx = canvas.getContext('2d')!;

    ctx.fillStyle = '#FFFFFF';
    ctx.fillRect(0, 0, totalW, totalH);

    for (let y = 0; y < canvasHeight; y++) {
      for (let x = 0; x < canvasWidth; x++) {
        const px = padding + x * (cellSize + padding);
        const py = padding + y * (cellSize + padding);
        if (grid[y][x]) {
          ctx.fillStyle = grid[y][x];
          ctx.fillRect(px, py, cellSize, cellSize);
        } else {
          ctx.strokeStyle = '#CCCCCC';
          ctx.strokeRect(px, py, cellSize, cellSize);
        }
      }
    }

    const win = window.open('', '_blank');
    if (win) {
      win.document.write(`
        <!DOCTYPE html>
        <html>
        <head>
          <title>拼豆图纸 - 打印</title>
          <style>
            body { text-align: center; font-family: sans-serif; padding: 20px; }
            img { max-width: 100%; image-rendering: pixelated; border: 2px solid #333; }
            .info { margin-top: 10px; font-size: 14px; color: #666; }
            @media print { body { padding: 0; } }
          </style>
        </head>
        <body>
          <img src="${canvas.toDataURL('image/png')}" />
          <p class="info">尺寸: ${canvasWidth} x ${canvasHeight} 格 | 拼豆豆工坊</p>
          <script>window.onload = function() { window.print(); }<\/script>
        </body>
        </html>
      `);
      win.document.close();
    }
  }

  // ===== 分享功能 =====
  function openShareModal() {
    const modal = document.getElementById('share-modal') as HTMLElement;
    modal.style.display = 'flex';
  }

  function closeShareModal() {
    const modal = document.getElementById('share-modal') as HTMLElement;
    modal.style.display = 'none';
  }

  function copyShareLink() {
    const title = (document.getElementById('share-title') as HTMLInputElement).value || '未命名作品';
    const data = { width: canvasWidth, height: canvasHeight, grid, title };
    const encoded = btoa(unescape(encodeURIComponent(JSON.stringify(data))));
    const link = `${window.location.origin}/design/shared?work=${encoded}`;

    navigator.clipboard.writeText(link).then(() => {
      alert('分享链接已复制到剪贴板！');
    }).catch(() => {
      prompt('请手动复制分享链接：', link);
    });
  }

  function publishToCommunity() {
    const title = (document.getElementById('share-title') as HTMLInputElement).value || '未命名作品';
    const author = (document.getElementById('share-author') as HTMLInputElement).value || '匿名';
    const desc = (document.getElementById('share-desc') as HTMLTextAreaElement).value || '';

    const work = {
      id: 'work-' + Date.now(),
      title,
      author,
      description: desc,
      width: canvasWidth,
      height: canvasHeight,
      grid,
      colors: getUsedColors(),
      likes: 0,
      createdAt: new Date().toISOString(),
    };

    try {
      const works = JSON.parse(localStorage.getItem(COMMUNITY_KEY) || '[]');
      works.unshift(work);
      localStorage.setItem(COMMUNITY_KEY, JSON.stringify(works));
      alert('作品已发布到社区！');
      closeShareModal();
    } catch {
      alert('发布失败，请稍后重试。');
    }
  }

  function getUsedColors(): string[] {
    const colorSet = new Set<string>();
    for (const row of grid) {
      for (const cell of row) {
        if (cell) colorSet.add(cell);
      }
    }
    return Array.from(colorSet);
  }

  // ===== 工具切换 =====
  function setTool(tool: 'brush' | 'eraser' | 'fill' | 'picker') {
    currentTool = tool;
    document.querySelectorAll('.tool-btn').forEach((btn) => {
      btn.classList.toggle('active', btn.dataset.tool === tool);
    });
    // 更新光标
    document.querySelectorAll('.pixel-cell').forEach((cell) => {
      (cell as HTMLElement).style.cursor = tool === 'picker' ? 'crosshair' : 'pointer';
    });
  }

  // ===== 事件绑定 =====
  function bindEvents() {
    // 鼠标抬起停止绘制
    document.addEventListener('mouseup', () => { isDrawing = false; });

    // 工具按钮
    document.querySelectorAll('.tool-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        setTool(btn.dataset.tool as 'brush' | 'eraser' | 'fill' | 'picker');
      });
    });

    // 操作按钮
    document.getElementById('undo-btn')!.addEventListener('click', undo);
    document.getElementById('redo-btn')!.addEventListener('click', redo);
    document.getElementById('clear-btn')!.addEventListener('click', () => {
      if (confirm('确定要清空画布吗？')) {
        pushUndo();
        grid = createEmptyGrid(canvasWidth, canvasHeight);
        renderCanvas();
        saveToStorage();
      }
    });

    // 导出按钮
    document.getElementById('export-png-btn')!.addEventListener('click', exportPNG);
    document.getElementById('export-pdf-btn')!.addEventListener('click', printPDF);
    document.getElementById('export-json-btn')!.addEventListener('click', exportJSON);

    // 分享按钮
    document.getElementById('share-btn')!.addEventListener('click', openShareModal);
    document.getElementById('modal-close-btn')!.addEventListener('click', closeShareModal);
    document.getElementById('copy-link-btn')!.addEventListener('click', copyShareLink);
    document.getElementById('publish-btn')!.addEventListener('click', publishToCommunity);

    // 点击模态框外部关闭
    document.getElementById('share-modal')!.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).id === 'share-modal') closeShareModal();
    });

    // 画布尺寸
    document.getElementById('apply-size-btn')!.addEventListener('click', () => {
      const w = parseInt((document.getElementById('canvas-width') as HTMLInputElement).value) || 20;
      const h = parseInt((document.getElementById('canvas-height') as HTMLInputElement).value) || 20;
      const newW = Math.max(5, Math.min(50, w));
      const newH = Math.max(5, Math.min(50, h));

      if (newW !== canvasWidth || newH !== canvasHeight) {
        pushUndo();
        const newGrid = createEmptyGrid(newW, newH);
        for (let y = 0; y < Math.min(canvasHeight, newH); y++) {
          for (let x = 0; x < Math.min(canvasWidth, newW); x++) {
            newGrid[y][x] = grid[y][x];
          }
        }
        canvasWidth = newW;
        canvasHeight = newH;
        grid = newGrid;
        renderCanvas();
        saveToStorage();
      }
    });

    // 键盘快捷键
    document.addEventListener('keydown', (e) => {
      if (e.ctrlKey || e.metaKey) {
        if (e.key === 'z') { e.preventDefault(); undo(); }
        if (e.key === 'y') { e.preventDefault(); redo(); }
      }
      if (!e.ctrlKey && !e.metaKey && !e.altKey) {
        if (e.key === 'b') setTool('brush');
        if (e.key === 'e') setTool('eraser');
        if (e.key === 'f') setTool('fill');
        if (e.key === 'i') setTool('picker');
      }
    });

    // 窗口大小变化重新渲染
    window.addEventListener('resize', () => {
      renderCanvas();
    });
  }

  // ===== 启动 =====
  document.addEventListener('DOMContentLoaded', init);
</script>


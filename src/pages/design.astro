---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="设计工具">
  <Header activeNav="designer" />
  
  <main class="design-page">
    <div class="container">
      <div class="coming-soon-container">
        <!-- 像素风格装饰 -->
        <div class="pixel-decoration">
          <div class="pixel-grid">
            <div class="pixel-row">
              <span class="pixel" style="--color: #FF6B6B; --delay: 0s;"></span>
              <span class="pixel" style="--color: #4ECDC4; --delay: 0.1s;"></span>
              <span class="pixel" style="--color: #FFE66D; --delay: 0.2s;"></span>
              <span class="pixel" style="--color: #FF6B6B; --delay: 0.3s;"></span>
              <span class="pixel" style="--color: #4ECDC4; --delay: 0.4s;"></span>
            </div>
            <div class="pixel-row">
              <span class="pixel" style="--color: #4ECDC4; --delay: 0.1s;"></span>
              <span class="pixel" style="--color: #FFE66D; --delay: 0.2s;"></span>
              <span class="pixel" style="--color: #FF6B6B; --delay: 0.3s;"></span>
              <span class="pixel" style="--color: #4ECDC4; --delay: 0.4s;"></span>
              <span class="pixel" style="--color: #FFE66D; --delay: 0.5s;"></span>
            </div>
            <div class="pixel-row">
              <span class="pixel" style="--color: #FFE66D; --delay: 0.2s;"></span>
              <span class="pixel" style="--color: #FF6B6B; --delay: 0.3s;"></span>
              <span class="pixel" style="--color: #4ECDC4; --delay: 0.4s;"></span>
              <span class="pixel" style="--color: #FFE66D; --delay: 0.5s;"></span>
              <span class="pixel" style="--color: #FF6B6B; --delay: 0.6s;"></span>
            </div>
          </div>
        </div>
        
        <!-- 提示框 -->
        <div class="pixel-speech-bubble">
          <div class="bubble-content">
            <span class="tool-icon">🎨</span>
            <h1 class="page-title">设计工具开发中...</h1>
            <p class="page-description">
              我们正在努力打造一个强大的在线拼豆设计工具<br/>
              届时您可以自由创作属于自己的像素艺术作品
            </p>
            <div class="feature-preview">
              <h3 class="preview-title">即将推出功能：</h3>
              <ul class="feature-list">
                <li>🖌️ 自由绘制像素图案</li>
                <li>🎨 丰富的颜色选择器</li>
                <li>📐 自定义画布尺寸</li>
                <li>💾 保存与导出图纸</li>
                <li>🔄 撤销/重做支持</li>
              </ul>
            </div>
          </div>
          <div class="bubble-tail"></div>
        </div>
        
        <!-- 返回按钮 -->
        <div class="action-section">
          <a href="/patterns" class="pixel-btn">
            <span class="btn-icon">📚</span>
            浏览图纸库
          </a>
          <a href="/" class="pixel-btn secondary">
            <span class="btn-icon">🏠</span>
            返回首页
          </a>
        </div>
        
        <!-- 进度指示器 -->
        <div class="progress-section">
          <div class="progress-label">
            <span class="label-text">开发进度</span>
            <span class="label-value">35%</span>
          </div>
          <div class="progress-bar">
            <div class="progress-fill" style="width: 35%;"></div>
          </div>
        </div>
      </div>
    </div>
  </main>
  
  <Footer />
</Layout>

<style>
  .design-page {
    padding: var(--spacing-2xl) 0;
    min-height: calc(100vh - 70px - 300px);
    display: flex;
    align-items: center;
  }
  
  .coming-soon-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }
  
  /* 像素装饰 */
  .pixel-decoration {
    margin-bottom: var(--spacing-xl);
  }
  
  .pixel-grid {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  
  .pixel-row {
    display: flex;
    gap: 4px;
    justify-content: center;
  }
  
  .pixel {
    width: 24px;
    height: 24px;
    background-color: var(--color);
    border: 3px solid var(--color-border);
    animation: pixelBlink 1.5s ease-in-out infinite;
    animation-delay: var(--delay);
  }
  
  @keyframes pixelBlink {
    0%, 100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.6;
      transform: scale(0.9);
    }
  }
  
  /* 像素风格提示框 */
  .pixel-speech-bubble {
    position: relative;
    background-color: var(--color-white);
    border: 4px solid var(--color-border);
    box-shadow: 8px 8px 0 var(--color-shadow);
    margin-bottom: var(--spacing-xl);
    max-width: 500px;
  }
  
  .bubble-content {
    padding: var(--spacing-xl);
  }
  
  .tool-icon {
    font-size: 3rem;
    display: block;
    margin-bottom: var(--spacing-md);
  }
  
  .page-title {
    font-size: 1.25rem;
    color: var(--color-primary);
    margin-bottom: var(--spacing-md);
  }
  
  .page-description {
    font-size: 0.875rem;
    color: var(--color-text);
    opacity: 0.8;
    line-height: 1.8;
    margin-bottom: var(--spacing-xl);
  }
  
  /* 功能预览 */
  .feature-preview {
    background-color: var(--color-background);
    border: 3px solid var(--color-border);
    padding: var(--spacing-lg);
    text-align: left;
  }
  
  .preview-title {
    font-family: var(--font-pixel);
    font-size: 0.625rem;
    color: var(--color-text);
    margin-bottom: var(--spacing-md);
  }
  
  .feature-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-sm);
  }
  
  @media (max-width: 480px) {
    .feature-list {
      grid-template-columns: 1fr;
    }
  }
  
  .feature-list li {
    font-size: 0.875rem;
    color: var(--color-text);
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
  }
  
  /* 气泡尾巴 */
  .bubble-tail {
    position: absolute;
    bottom: -20px;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 0;
    border-left: 20px solid transparent;
    border-right: 20px solid transparent;
    border-top: 20px solid var(--color-border);
  }
  
  .bubble-tail::after {
    content: '';
    position: absolute;
    top: -24px;
    left: -16px;
    width: 0;
    height: 0;
    border-left: 16px solid transparent;
    border-right: 16px solid transparent;
    border-top: 16px solid var(--color-white);
  }
  
  /* 操作区域 */
  .action-section {
    display: flex;
    gap: var(--spacing-md);
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: var(--spacing-xl);
  }
  
  .pixel-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-sm);
    font-size: 0.875rem;
    padding: var(--spacing-md) var(--spacing-lg);
  }
  
  .btn-icon {
    font-size: 1.25rem;
  }
  
  /* 进度条 */
  .progress-section {
    width: 100%;
    max-width: 400px;
  }
  
  .progress-label {
    display: flex;
    justify-content: space-between;
    margin-bottom: var(--spacing-sm);
  }
  
  .label-text {
    font-family: var(--font-pixel);
    font-size: 0.625rem;
    color: var(--color-text);
  }
  
  .label-value {
    font-family: var(--font-pixel);
    font-size: 0.625rem;
    color: var(--color-primary);
  }
  
  .progress-bar {
    height: 24px;
    background-color: var(--color-white);
    border: 3px solid var(--color-border);
    box-shadow: 4px 4px 0 var(--color-shadow);
    overflow: hidden;
  }
  
  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--color-primary) 0%, var(--color-secondary) 100%);
    transition: width 0.5s ease;
    position: relative;
  }
  
  .progress-fill::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: repeating-linear-gradient(
      90deg,
      transparent,
      transparent 10px,
      rgba(255, 255, 255, 0.3) 10px,
      rgba(255, 255, 255, 0.3) 20px
    );
    animation: progressShine 1s linear infinite;
  }
  
  @keyframes progressShine {
    0% {
      transform: translateX(-20px);
    }
    100% {
      transform: translateX(0);
    }
  }
  
  /* 响应式调整 */
  @media (max-width: 480px) {
    .pixel-speech-bubble {
      margin: 0 var(--spacing-md) var(--spacing-xl);
    }
    
    .bubble-content {
      padding: var(--spacing-lg);
    }
    
    .page-title {
      font-size: 1rem;
    }
    
    .action-section {
      flex-direction: column;
      width: 100%;
      padding: 0 var(--spacing-md);
    }
    
    .pixel-btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>

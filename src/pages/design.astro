---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="设计工具" description="在线创作您的专属拼豆图纸">
  <Header activeNav="design" />
  
  <main class="design-page">
    <div class="container">
      <!-- 页面标题 -->
      <div class="page-header">
        <h1 class="page-title">
          <span class="title-icon">🎨</span>
          拼豆设计工具
        </h1>
        <p class="page-desc">在线创作您的专属拼豆作品，支持导出打印</p>
      </div>
      
      <!-- 设计器主体 -->
      <div class="designer-container">
        <!-- 工具栏 -->
        <div class="toolbar">
          <div class="tool-group">
            <h3 class="group-title">画布设置</h3>
            <div class="input-row">
              <label>宽度:</label>
              <input type="number" id="gridWidth" value="20" min="5" max="50" class="pixel-input">
              <span>格</span>
            </div>
            <div class="input-row">
              <label>高度:</label>
              <input type="number" id="gridHeight" value="20" min="5" max="50" class="pixel-input">
              <span>格</span>
            </div>
            <button id="resizeGrid" class="pixel-btn small">应用</button>
          </div>
          
          <div class="tool-group">
            <h3 class="group-title">工具</h3>
            <div class="tool-buttons">
              <button id="toolPen" class="tool-btn active" data-tool="pen" title="画笔">
                <span>✏️</span>
              </button>
              <button id="toolEraser" class="tool-btn" data-tool="eraser" title="橡皮擦">
                <span>🧼</span>
              </button>
              <button id="toolFill" class="tool-btn" data-tool="fill" title="填充">
                <span>🪣</span>
              </button>
              <button id="toolPicker" class="tool-btn" data-tool="picker" title="取色器">
                <span>💧</span>
              </button>
            </div>
          </div>
          
          <div class="tool-group">
            <h3 class="group-title">操作</h3>
            <div class="action-buttons">
              <button id="undoBtn" class="pixel-btn small">↩️ 撤销</button>
              <button id="redoBtn" class="pixel-btn small">↪️ 重做</button>
              <button id="clearBtn" class="pixel-btn small danger">🗑️ 清空</button>
            </div>
          </div>
          
          <div class="tool-group">
            <h3 class="group-title">导出</h3>
            <div class="export-buttons">
              <button id="exportPNG" class="pixel-btn">📥 下载PNG</button>
              <button id="exportPDF" class="pixel-btn secondary">📄 打印PDF</button>
            </div>
          </div>
          
          <div class="tool-group">
            <h3 class="group-title">社区</h3>
            <div class="export-buttons">
              <button id="shareWork" class="pixel-btn share">🌐 分享作品</button>
              <button id="exportJSON" class="pixel-btn small">📦 导出JSON</button>
            </div>
          </div>
        </div>
        
        <!-- 画布区域 -->
        <div class="canvas-area">
          <div class="canvas-wrapper">
            <div id="pixelGrid" class="pixel-grid"></div>
          </div>
          <div class="canvas-info">
            <span id="gridInfo">20 × 20 格</span>
            <span id="pixelCount">已用: 0 颗</span>
          </div>
        </div>
        
        <!-- 颜色面板 -->
        <div class="color-panel">
          <h3 class="panel-title">🎨 颜色选择</h3>
          <div id="colorPalette" class="color-palette">
            <!-- 颜色由JS生成 -->
          </div>
          <div class="current-color">
            <span>当前颜色:</span>
            <div id="currentColor" class="color-preview" style="background-color: #FF6B6B;"></div>
            <span id="colorName">红色</span>
          </div>
          
          <!-- 常用颜色 -->
          <div class="quick-colors">
            <h4 class="sub-title">最近使用</h4>
            <div id="recentColors" class="recent-colors"></div>
          </div>
        </div>
      </div>
      
      <!-- 使用提示 -->
      <div class="tips-section">
        <h2 class="tips-title">💡 使用提示</h2>
        <div class="tips-grid">
          <div class="tip-item">
            <span class="tip-icon">🖱️</span>
            <p>左键点击绘制，右键擦除</p>
          </div>
          <div class="tip-item">
            <span class="tip-icon">↔️</span>
            <p>按住拖动连续绘制</p>
          </div>
          <div class="tip-item">
            <span class="tip-icon">💾</span>
            <p>自动保存到浏览器</p>
          </div>
          <div class="tip-item">
            <span class="tip-icon">📐</span>
            <p>建议尺寸不超过 30×30</p>
          </div>
        </div>
      </div>
    </div>
  </main>
  
  <Footer />
</Layout>

<script>
  // 拼豆颜色库
  const beadColors = [
    { name: '红色', hex: '#FF6B6B', code: 'R01' },
    { name: '橙色', hex: '#FF8E53', code: 'R02' },
    { name: '黄色', hex: '#FFE66D', code: 'Y01' },
    { name: '绿色', hex: '#4ECDC4', code: 'G01' },
    { name: '青色', hex: '#45B7D1', code: 'G02' },
    { name: '蓝色', hex: '#5B8DEF', code: 'B01' },
    { name: '紫色', hex: '#9B59B6', code: 'P01' },
    { name: '粉色', hex: '#FF6B9D', code: 'P02' },
    { name: '棕色', hex: '#8B4513', code: 'N01' },
    { name: '黑色', hex: '#2D3436', code: 'K01' },
    { name: '白色', hex: '#FFFFFF', code: 'W01' },
    { name: '灰色', hex: '#636E72', code: 'N02' },
    { name: '浅粉', hex: '#FFB8D0', code: 'P03' },
    { name: '浅蓝', hex: '#A8E6CF', code: 'B02' },
    { name: '米色', hex: '#FFE4C4', code: 'Y02' },
    { name: '深红', hex: '#C0392B', code: 'R03' },
  ];

  // 状态管理
  let state = {
    width: 20,
    height: 20,
    currentColor: beadColors[0],
    currentTool: 'pen',
    isDrawing: false,
    grid: [],
    history: [],
    historyIndex: -1,
    recentColors: []
  };

  // DOM 元素
  const gridEl = document.getElementById('pixelGrid');
  const colorPaletteEl = document.getElementById('colorPalette');
  const currentColorEl = document.getElementById('currentColor');
  const colorNameEl = document.getElementById('colorName');
  const recentColorsEl = document.getElementById('recentColors');
  const gridInfoEl = document.getElementById('gridInfo');
  const pixelCountEl = document.getElementById('pixelCount');

  // 初始化
  function init() {
    loadFromStorage();
    createGrid();
    createColorPalette();
    bindEvents();
    updateRecentColors();
    saveState();
  }

  // 创建网格
  function createGrid() {
    gridEl.innerHTML = '';
    gridEl.style.gridTemplateColumns = `repeat(${state.width}, 1fr)`;
    
    state.grid = [];
    for (let y = 0; y < state.height; y++) {
      const row = [];
      for (let x = 0; x < state.width; x++) {
        const cell = document.createElement('div');
        cell.className = 'grid-cell';
        cell.dataset.x = x;
        cell.dataset.y = y;
        cell.addEventListener('mousedown', handleCellClick);
        cell.addEventListener('mouseenter', handleCellHover);
        cell.addEventListener('contextmenu', handleRightClick);
        gridEl.appendChild(cell);
        row.push(null);
      }
      state.grid.push(row);
    }
    
    // 恢复历史数据
    if (state.history.length > 0 && state.historyIndex >= 0) {
      restoreGrid(state.history[state.historyIndex]);
    }
    
    updateGridInfo();
  }

  // 创建颜色面板
  function createColorPalette() {
    colorPaletteEl.innerHTML = '';
    beadColors.forEach(color => {
      const colorBtn = document.createElement('button');
      colorBtn.className = 'color-btn';
      colorBtn.style.backgroundColor = color.hex;
      colorBtn.title = `${color.name} (${color.code})`;
      colorBtn.dataset.color = JSON.stringify(color);
      if (color.hex === state.currentColor.hex) {
        colorBtn.classList.add('active');
      }
      colorBtn.addEventListener('click', () => selectColor(color));
      colorPaletteEl.appendChild(colorBtn);
    });
  }

  // 选择颜色
  function selectColor(color) {
    state.currentColor = color;
    currentColorEl.style.backgroundColor = color.hex;
    colorNameEl.textContent = color.name;
    
    // 更新颜色按钮状态
    document.querySelectorAll('.color-btn').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.color === JSON.stringify(color));
    });
    
    // 添加到最近使用
    addRecentColor(color);
  }

  // 添加最近使用颜色
  function addRecentColor(color) {
    state.recentColors = state.recentColors.filter(c => c.hex !== color.hex);
    state.recentColors.unshift(color);
    if (state.recentColors.length > 8) {
      state.recentColors.pop();
    }
    updateRecentColors();
  }

  // 更新最近使用颜色
  function updateRecentColors() {
    recentColorsEl.innerHTML = '';
    state.recentColors.forEach(color => {
      const btn = document.createElement('button');
      btn.className = 'recent-color-btn';
      btn.style.backgroundColor = color.hex;
      btn.title = color.name;
      btn.addEventListener('click', () => selectColor(color));
      recentColorsEl.appendChild(btn);
    });
  }

  // 处理单元格点击
  function handleCellClick(e) {
    e.preventDefault();
    const x = parseInt(e.target.dataset.x);
    const y = parseInt(e.target.dataset.y);
    
    state.isDrawing = true;
    
    if (state.currentTool === 'pen') {
      setPixel(x, y, state.currentColor);
    } else if (state.currentTool === 'eraser') {
      setPixel(x, y, null);
    } else if (state.currentTool === 'fill') {
      floodFill(x, y, state.currentColor);
    } else if (state.currentTool === 'picker') {
      const color = state.grid[y][x];
      if (color) selectColor(color);
    }
    
    saveState();
  }

  // 处理鼠标悬停
  function handleCellHover(e) {
    if (!state.isDrawing) return;
    const x = parseInt(e.target.dataset.x);
    const y = parseInt(e.target.dataset.y);
    
    if (state.currentTool === 'pen') {
      setPixel(x, y, state.currentColor);
    } else if (state.currentTool === 'eraser') {
      setPixel(x, y, null);
    }
  }

  // 右键擦除
  function handleRightClick(e) {
    e.preventDefault();
    const x = parseInt(e.target.dataset.x);
    const y = parseInt(e.target.dataset.y);
    setPixel(x, y, null);
    saveState();
  }

  // 设置像素
  function setPixel(x, y, color) {
    if (x < 0 || x >= state.width || y < 0 || y >= state.height) return;
    
    state.grid[y][x] = color;
    const cell = gridEl.children[y * state.width + x];
    
    if (color) {
      cell.style.backgroundColor = color.hex;
      cell.classList.add('filled');
    } else {
      cell.style.backgroundColor = '';
      cell.classList.remove('filled');
    }
    
    updatePixelCount();
  }

  // 填充算法
  function floodFill(startX, startY, fillColor) {
    const targetColor = state.grid[startY][startX];
    if (targetColor && targetColor.hex === fillColor.hex) return;
    
    const stack = [[startX, startY]];
    const visited = new Set();
    
    while (stack.length > 0) {
      const [x, y] = stack.pop();
      const key = `${x},${y}`;
      
      if (visited.has(key)) continue;
      if (x < 0 || x >= state.width || y < 0 || y >= state.height) continue;
      
      const currentColor = state.grid[y][x];
      if (targetColor === null ? currentColor !== null : !currentColor || currentColor.hex !== targetColor.hex) continue;
      
      visited.add(key);
      setPixel(x, y, fillColor);
      
      stack.push([x + 1, y], [x - 1, y], [x, y + 1], [x, y - 1]);
    }
  }

  // 保存状态到历史
  function saveState() {
    const gridCopy = state.grid.map(row => row.map(cell => cell ? { ...cell } : null));
    
    // 删除当前索引之后的历史
    state.history = state.history.slice(0, state.historyIndex + 1);
    state.history.push(gridCopy);
    state.historyIndex++;
    
    // 限制历史记录数量
    if (state.history.length > 50) {
      state.history.shift();
      state.historyIndex--;
    }
    
    saveToStorage();
  }

  // 撤销
  function undo() {
    if (state.historyIndex > 0) {
      state.historyIndex--;
      restoreGrid(state.history[state.historyIndex]);
    }
  }

  // 重做
  function redo() {
    if (state.historyIndex < state.history.length - 1) {
      state.historyIndex++;
      restoreGrid(state.history[state.historyIndex]);
    }
  }

  // 恢复网格
  function restoreGrid(gridData) {
    state.grid = gridData.map(row => row.map(cell => cell ? { ...cell } : null));
    
    for (let y = 0; y < state.height; y++) {
      for (let x = 0; x < state.width; x++) {
        const cell = gridEl.children[y * state.width + x];
        const color = state.grid[y][x];
        
        if (color) {
          cell.style.backgroundColor = color.hex;
          cell.classList.add('filled');
        } else {
          cell.style.backgroundColor = '';
          cell.classList.remove('filled');
        }
      }
    }
    
    updatePixelCount();
  }

  // 清空画布
  function clearGrid() {
    if (confirm('确定要清空画布吗？此操作无法撤销。')) {
      for (let y = 0; y < state.height; y++) {
        for (let x = 0; x < state.width; x++) {
          setPixel(x, y, null);
        }
      }
      saveState();
    }
  }

  // 调整网格大小
  function resizeGrid() {
    const newWidth = parseInt(document.getElementById('gridWidth').value);
    const newHeight = parseInt(document.getElementById('gridHeight').value);
    
    if (newWidth < 5 || newWidth > 50 || newHeight < 5 || newHeight > 50) {
      alert('画布尺寸必须在 5-50 之间');
      return;
    }
    
    if (confirm('调整画布大小会清空当前内容，是否继续？')) {
      state.width = newWidth;
      state.height = newHeight;
      state.history = [];
      state.historyIndex = -1;
      createGrid();
      saveState();
    }
  }

  // 更新网格信息
  function updateGridInfo() {
    gridInfoEl.textContent = `${state.width} × ${state.height} 格`;
    updatePixelCount();
  }

  // 更新像素计数
  function updatePixelCount() {
    let count = 0;
    for (let y = 0; y < state.height; y++) {
      for (let x = 0; x < state.width; x++) {
        if (state.grid[y][x]) count++;
      }
    }
    pixelCountEl.textContent = `已用: ${count} 颗`;
  }

  // 导出PNG
  function exportPNG() {
    const canvas = document.createElement('canvas');
    const ctx = canvas.getContext('2d');
    const pixelSize = 20;
    
    canvas.width = state.width * pixelSize;
    canvas.height = state.height * pixelSize;
    
    // 绘制背景
    ctx.fillStyle = '#FFFFFF';
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    
    // 绘制网格线
    ctx.strokeStyle = '#E0E0E0';
    ctx.lineWidth = 1;
    for (let i = 0; i <= state.width; i++) {
      ctx.beginPath();
      ctx.moveTo(i * pixelSize, 0);
      ctx.lineTo(i * pixelSize, canvas.height);
      ctx.stroke();
    }
    for (let i = 0; i <= state.height; i++) {
      ctx.beginPath();
      ctx.moveTo(0, i * pixelSize);
      ctx.lineTo(canvas.width, i * pixelSize);
      ctx.stroke();
    }
    
    // 绘制像素
    for (let y = 0; y < state.height; y++) {
      for (let x = 0; x < state.width; x++) {
        const color = state.grid[y][x];
        if (color) {
          ctx.fillStyle = color.hex;
          ctx.fillRect(x * pixelSize + 1, y * pixelSize + 1, pixelSize - 2, pixelSize - 2);
        }
      }
    }
    
    // 下载
    const link = document.createElement('a');
    link.download = `拼豆设计_${state.width}x${state.height}_${Date.now()}.png`;
    link.href = canvas.toDataURL();
    link.click();
  }

  // 导出打印版PDF (实际是HTML打印)
  function exportPDF() {
    const printWindow = window.open('', '_blank');
    const pixelSize = 15;
    
    let gridHTML = '';
    for (let y = 0; y < state.height; y++) {
      gridHTML += '<tr>';
      for (let x = 0; x < state.width; x++) {
        const color = state.grid[y][x];
        const bgColor = color ? color.hex : '#FFFFFF';
        const borderColor = color ? '#000000' : '#CCCCCC';
        gridHTML += `<td style="width:${pixelSize}px;height:${pixelSize}px;background:${bgColor};border:1px solid ${borderColor};"></td>`;
      }
      gridHTML += '</tr>';
    }
    
    printWindow.document.write(`
      <!DOCTYPE html>
      <html>
      <head>
        <title>拼豆图纸 - 打印</title>
        <style>
          body { font-family: Arial, sans-serif; padding: 20px; }
          h1 { text-align: center; font-size: 18px; }
          .info { text-align: center; margin: 10px 0; font-size: 12px; color: #666; }
          table { border-collapse: collapse; margin: 20px auto; }
          td { box-sizing: border-box; }
          .legend { margin-top: 20px; font-size: 11px; }
          @media print {
            body { padding: 0; }
            .no-print { display: none; }
          }
        </style>
      </head>
      <body>
        <h1>🎨 拼豆豆工坊 - 制作图纸</h1>
        <div class="info">尺寸: ${state.width} × ${state.height} | 生成时间: ${new Date().toLocaleString()}</div>
        <table>${gridHTML}</table>
        <div class="legend">
          <p>💡 制作提示：</p>
          <p>1. 每个格子代表一颗拼豆</p>
          <p>2. 建议从中心或边缘开始制作</p>
          <p>3. 完成后用熨斗隔着烘焙纸熨烫</p>
        </div>
        <button class="no-print" onclick="window.print()" style="display:block;margin:20px auto;padding:10px 20px;">🖨️ 打印图纸</button>
      </body>
      </html>
    `);
    printWindow.document.close();
  }

  // 导出为JSON
  function exportJSON() {
    // 收集使用的颜色
    const usedColors = new Set();
    for (let y = 0; y < state.height; y++) {
      for (let x = 0; x < state.width; x++) {
        const color = state.grid[y][x];
        if (color) {
          usedColors.add(color.hex);
        }
      }
    }

    const data = {
      version: '1.0',
      title: '拼豆设计',
      width: state.width,
      height: state.height,
      grid: state.grid,
      colors: Array.from(usedColors),
      exportedAt: new Date().toISOString()
    };

    const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.download = `拼豆设计_${state.width}x${state.height}_${Date.now()}.json`;
    link.href = url;
    link.click();
    URL.revokeObjectURL(url);
  }

  // 分享/投稿作品
  function shareWork() {
    // 检查是否有内容
    let hasContent = false;
    for (let y = 0; y < state.height; y++) {
      for (let x = 0; x < state.width; x++) {
        if (state.grid[y][x]) {
          hasContent = true;
          break;
        }
      }
      if (hasContent) break;
    }

    if (!hasContent) {
      alert('请先绘制一些内容再分享！');
      return;
    }

    // 显示投稿模态框
    showShareModal();
  }

  // 显示分享模态框
  function showShareModal() {
    const modal = document.createElement('div');
    modal.className = 'share-modal';
    modal.innerHTML = `
      <div class="modal-content">
        <div class="modal-header">
          <h3>🌐 分享您的作品</h3>
          <button class="modal-close">&times;</button>
        </div>
        <div class="modal-body">
          <p class="modal-desc">将您的作品分享到社区，让更多人看到您的创意！</p>
          <div class="form-group">
            <label for="workTitle">作品名称 *</label>
            <input type="text" id="workTitle" placeholder="给您的作品起个名字" maxlength="50">
          </div>
          <div class="form-group">
            <label for="workAuthor">作者昵称</label>
            <input type="text" id="workAuthor" placeholder="输入您的昵称（选填）" maxlength="30">
          </div>
          <div class="form-group">
            <label for="workDesc">作品描述</label>
            <textarea id="workDesc" placeholder="介绍一下您的作品（选填）" maxlength="200"></textarea>
          </div>
          <div class="form-group">
            <label>或者：</label>
            <button class="copy-link-btn">📋 复制分享链接</button>
            <p class="hint">复制链接后，可以直接发送给朋友</p>
          </div>
        </div>
        <div class="modal-footer">
          <button class="modal-btn cancel">取消</button>
          <button class="modal-btn submit">发布到社区</button>
        </div>
      </div>
    `;
    document.body.appendChild(modal);

    // 添加模态框样式
    const style = document.createElement('style');
    style.textContent = `
      .share-modal {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0,0,0,0.6);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
        padding: 20px;
      }
      .modal-content {
        background: #fff;
        border: 4px solid var(--color-border, #333);
        box-shadow: 8px 8px 0 var(--color-border, #333);
        max-width: 400px;
        width: 100%;
        max-height: 90vh;
        overflow-y: auto;
      }
      .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px;
        border-bottom: 3px solid var(--color-border, #333);
      }
      .modal-header h3 {
        font-family: var(--font-pixel, monospace);
        margin: 0;
        font-size: 14px;
      }
      .modal-close {
        background: none;
        border: none;
        font-size: 24px;
        cursor: pointer;
        line-height: 1;
      }
      .modal-body {
        padding: 16px;
      }
      .modal-desc {
        margin: 0 0 16px;
        font-size: 13px;
        color: #666;
      }
      .form-group {
        margin-bottom: 16px;
      }
      .form-group label {
        display: block;
        font-family: var(--font-pixel, monospace);
        font-size: 11px;
        margin-bottom: 6px;
      }
      .form-group input,
      .form-group textarea {
        width: 100%;
        padding: 10px;
        border: 2px solid var(--color-border, #333);
        font-family: inherit;
        font-size: 13px;
        box-sizing: border-box;
      }
      .form-group textarea {
        height: 80px;
        resize: vertical;
      }
      .copy-link-btn {
        width: 100%;
        padding: 10px;
        background: var(--color-secondary, #4ECDC4);
        color: white;
        border: 2px solid var(--color-border, #333);
        cursor: pointer;
        font-family: var(--font-pixel, monospace);
        font-size: 12px;
      }
      .copy-link-btn:hover {
        opacity: 0.9;
      }
      .hint {
        font-size: 11px;
        color: #999;
        margin: 6px 0 0;
      }
      .modal-footer {
        display: flex;
        gap: 12px;
        padding: 16px;
        border-top: 3px solid var(--color-border, #333);
      }
      .modal-btn {
        flex: 1;
        padding: 12px;
        font-family: var(--font-pixel, monospace);
        font-size: 11px;
        cursor: pointer;
        border: 2px solid var(--color-border, #333);
      }
      .modal-btn.cancel {
        background: #fff;
      }
      .modal-btn.submit {
        background: #FF6B6B;
        color: white;
      }
    `;
    document.head.appendChild(style);

    // 事件绑定
    modal.querySelector('.modal-close').onclick = () => modal.remove();
    modal.querySelector('.cancel').onclick = () => modal.remove();
    modal.onclick = (e) => {
      if (e.target === modal) modal.remove();
    };

    // 复制链接按钮
    modal.querySelector('.copy-link-btn').onclick = () => {
      const title = document.getElementById('workTitle').value || '我的拼豆作品';
      const jsonData = {
        title,
        width: state.width,
        height: state.height,
        grid: state.grid
      };
      const encoded = btoa(encodeURIComponent(JSON.stringify(jsonData)));
      const shareUrl = `${window.location.origin}/design?work=${encoded}`;
      
      navigator.clipboard.writeText(shareUrl).then(() => {
        modal.querySelector('.copy-link-btn').textContent = '✅ 已复制！';
        setTimeout(() => {
          modal.querySelector('.copy-link-btn').textContent = '📋 复制分享链接';
        }, 2000);
      }).catch(() => {
        // Fallback
        const textarea = document.createElement('textarea');
        textarea.value = shareUrl;
        document.body.appendChild(textarea);
        textarea.select();
        document.execCommand('copy');
        document.body.removeChild(textarea);
        modal.querySelector('.copy-link-btn').textContent = '✅ 已复制！';
      });
    };

    // 发布按钮
    modal.querySelector('.submit').onclick = async () => {
      const title = document.getElementById('workTitle').value.trim();
      const author = document.getElementById('workAuthor').value.trim() || '匿名用户';
      const description = document.getElementById('workDesc').value.trim();

      if (!title) {
        alert('请输入作品名称！');
        return;
      }

      // 收集颜色
      const usedColors = new Set();
      for (let y = 0; y < state.height; y++) {
        for (let x = 0; x < state.width; x++) {
          const color = state.grid[y][x];
          if (color) usedColors.add(color.hex);
        }
      }

      const workData = {
        title,
        author,
        description,
        width: state.width,
        height: state.height,
        grid: state.grid,
        colors: Array.from(usedColors)
      };

      const submitBtn = modal.querySelector('.submit');
      submitBtn.textContent = '发布中...';
      submitBtn.disabled = true;

      // 生成作品ID
      const workId = 'work_' + Date.now();
      const workDataWithId = {
        id: workId,
        ...workData,
        likes: 0,
        views: 1,
        createdAt: Date.now()
      };

      // 尝试发送到API
      let apiSuccess = false;
      try {
        const response = await fetch('/api/works', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(workDataWithId)
        });

        if (response.ok) {
          const result = await response.json();
          if (result.success) {
            apiSuccess = true;
            modal.remove();
            const shareUrl = `${window.location.origin}/design?view=${workId}`;
            alert(`🎉 作品发布成功！\n\n分享链接：\n${shareUrl}\n\n（链接已复制到剪贴板）`);
            navigator.clipboard.writeText(shareUrl);
          }
        }
      } catch (error) {
        console.log('API 发布失败，将保存到本地');
      }

      // 无论API是否成功，都保存到本地缓存
      const works = JSON.parse(localStorage.getItem('perlerCommunityWorks') || '[]');
      works.unshift(workDataWithId);
      localStorage.setItem('perlerCommunityWorks', JSON.stringify(works));

      if (!apiSuccess) {
        modal.remove();
        const shareUrl = `${window.location.origin}/design?view=${workId}`;
        alert(`📋 作品已保存到本地！\n\n分享链接：\n${shareUrl}\n\n（链接已复制到剪贴板）\n\n注意：作品仅在当前设备可见`);
        navigator.clipboard.writeText(shareUrl);
      }
    };
  }

  // 保存到本地存储
  function saveToStorage() {
    const data = {
      width: state.width,
      height: state.height,
      grid: state.grid,
      recentColors: state.recentColors,
      timestamp: Date.now()
    };
    localStorage.setItem('perlerDesigner', JSON.stringify(data));
  }

  // 从本地存储加载
  function loadFromStorage() {
    // 首先检查 URL 参数是否有分享的作品
    const urlParams = new URLSearchParams(window.location.search);
    const viewId = urlParams.get('view');
    
    if (viewId && viewId.startsWith('work_')) {
      // 从本地存储加载社区作品
      const works = JSON.parse(localStorage.getItem('perlerCommunityWorks') || '[]');
      const work = works.find(w => w.id === viewId);
      
      if (work) {
        state.width = work.width || 20;
        state.height = work.height || 20;
        state.grid = work.grid || [];
        state.recentColors = [];
        
        document.getElementById('gridWidth').value = state.width;
        document.getElementById('gridHeight').value = state.height;
        
        // 显示提示
        showNotification('已加载分享的作品：' + (work.title || '未命名'));
        return;
      }
    }
    
    // 检查是否有 work 参数（base64 编码的作品数据）
    const workParam = urlParams.get('work');
    if (workParam) {
      try {
        const workData = JSON.parse(decodeURIComponent(atob(workParam)));
        state.width = workData.width || 20;
        state.height = workData.height || 20;
        state.grid = workData.grid || [];
        state.recentColors = [];
        
        document.getElementById('gridWidth').value = state.width;
        document.getElementById('gridHeight').value = state.height;
        
        showNotification('已加载分享的作品');
        return;
      } catch (e) {
        console.error('解析分享数据失败', e);
      }
    }
    
    // 从本地存储加载
    const saved = localStorage.getItem('perlerDesigner');
    if (saved) {
      try {
        const data = JSON.parse(saved);
        state.width = data.width || 20;
        state.height = data.height || 20;
        state.grid = data.grid || [];
        state.recentColors = data.recentColors || [];
        
        document.getElementById('gridWidth').value = state.width;
        document.getElementById('gridHeight').value = state.height;
      } catch (e) {
        console.error('加载保存的数据失败', e);
      }
    }
  }
  
  // 显示通知
  function showNotification(message) {
    const notification = document.createElement('div');
    notification.className = 'design-notification';
    notification.textContent = message;
    notification.style.cssText = `
      position: fixed;
      top: 80px;
      left: 50%;
      transform: translateX(-50%);
      padding: 12px 24px;
      background: #4ECDC4;
      color: white;
      border: 3px solid #2D3436;
      box-shadow: 4px 4px 0 #2D3436;
      font-family: 'Press Start 2P', monospace;
      font-size: 0.625rem;
      z-index: 1000;
      animation: slideDown 0.3s ease;
    `;
    document.body.appendChild(notification);
    
    setTimeout(() => {
      notification.style.animation = 'slideUp 0.3s ease';
      setTimeout(() => notification.remove(), 300);
    }, 3000);
  }

  // 绑定事件
  function bindEvents() {
    // 工具按钮
    document.querySelectorAll('.tool-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.tool-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        state.currentTool = btn.dataset.tool;
      });
    });
    
    // 操作按钮
    document.getElementById('undoBtn').addEventListener('click', undo);
    document.getElementById('redoBtn').addEventListener('click', redo);
    document.getElementById('clearBtn').addEventListener('click', clearGrid);
    document.getElementById('resizeGrid').addEventListener('click', resizeGrid);
    document.getElementById('exportPNG').addEventListener('click', exportPNG);
    document.getElementById('exportPDF').addEventListener('click', exportPDF);
    
    // 分享按钮
    document.getElementById('shareWork').addEventListener('click', shareWork);
    document.getElementById('exportJSON').addEventListener('click', exportJSON);
    
    // 鼠标释放
    document.addEventListener('mouseup', () => {
      if (state.isDrawing) {
        state.isDrawing = false;
        saveState();
      }
    });
    
    // 键盘快捷键
    document.addEventListener('keydown', (e) => {
      if (e.ctrlKey || e.metaKey) {
        if (e.key === 'z') {
          e.preventDefault();
          undo();
        } else if (e.key === 'y' || (e.key === 'z' && e.shiftKey)) {
          e.preventDefault();
          redo();
        }
      }
    });
  }

  // 启动
  init();
</script>

